@model NovaStock.Web.Models.Warehouse
@inject NovaStock.Web.Data.ApplicationDbContext Db
@using Microsoft.EntityFrameworkCore
@{
    ViewData["Title"] = $"{Model.Name} – Depo Detayi";
    var allWarehouses = await Db.Warehouses.Where(w => w.Id != Model.Id && w.IsActive).ToListAsync();
    var totalQty = Model.ProductWarehouses.Sum(pw => pw.Quantity);
    var productCount = Model.ProductWarehouses.Count;
}

@section Styles {
<style>
    .transfer-modal-overlay {
        display: none;
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(4px);
        z-index: 2000;
        align-items: center; justify-content: center;
    }
    .transfer-modal-overlay.show { display: flex; }
    .transfer-modal {
        background: var(--bg-secondary);
        border: 1px solid var(--border-glass);
        border-radius: 20px;
        width: 100%; max-width: 480px;
        padding: 32px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        animation: modalIn 0.3s cubic-bezier(.4,0,.2,1);
    }
    @@keyframes modalIn {
        from { opacity: 0; transform: translateY(-20px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .stat-mini {
        background: rgba(99,102,241,0.06);
        border: 1px solid rgba(99,102,241,0.12);
        border-radius: 12px;
        padding: 16px 20px;
        display: flex; align-items: center; gap: 14px;
    }
    .stat-mini-icon {
        width: 42px; height: 42px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; flex-shrink: 0;
    }
    .product-row-hover:hover { background: rgba(99,102,241,0.04); }
    .qty-badge {
        display: inline-flex; align-items: center;
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.2);
        color: var(--green);
        padding: 3px 10px; border-radius: 20px;
        font-size: 12px; font-weight: 700;
    }
    .qty-badge.low  { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.2); color: var(--red); }
    .qty-badge.mid  { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.2); color: var(--yellow); }
</style>
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">
            <a href="/Warehouse" style="color:var(--text-muted);font-size:13px;text-decoration:none">
                <i class="fa-solid fa-warehouse"></i> Depolar
            </a>
            <i class="fa-solid fa-chevron-right" style="font-size:10px;color:var(--text-muted)"></i>
            <span style="font-size:13px;color:var(--text-primary);font-weight:500">@Model.Name</span>
        </div>
        <h1><i class="fa-solid fa-warehouse" style="color:var(--cyan);margin-right:10px"></i>@Model.Name</h1>
        <div class="breadcrumb-nova">
            <i class="fa-solid fa-location-dot" style="margin-right:4px;color:var(--accent-light)"></i>@Model.City
            @if (!string.IsNullOrEmpty(Model.Address)) { <span style="margin:0 6px;opacity:.4">•</span><text>@Model.Address</text> }
        </div>
    </div>
    <div style="display:flex;gap:10px;align-items:center">
        @if (Model.IsActive)
        {
            <span class="badge-nova badge-green"><i class="fa-solid fa-circle" style="font-size:7px;margin-right:4px"></i>Aktif Depo</span>
        }
        else
        {
            <span class="badge-nova badge-gray"><i class="fa-solid fa-circle" style="font-size:7px;margin-right:4px"></i>Pasif</span>
        }
        <a href="/Warehouse" class="btn-nova-outline"><i class="fa-solid fa-arrow-left"></i> Geri</a>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="stat-mini">
            <div class="stat-mini-icon" style="background:rgba(99,102,241,0.15);color:var(--accent)"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--accent)">@productCount</div>
                <div style="font-size:12px;color:var(--text-muted)">Urun Cesidi</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="stat-mini" style="background:rgba(6,182,212,0.06);border-color:rgba(6,182,212,0.12)">
            <div class="stat-mini-icon" style="background:rgba(6,182,212,0.15);color:var(--cyan)"><i class="fa-solid fa-cubes"></i></div>
            <div>
                <div style="font-size:22px;font-weight:800;color:var(--cyan)">@totalQty</div>
                <div style="font-size:12px;color:var(--text-muted)">Toplam Stok</div>
            </div>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.ManagerName))
    {
        <div class="col-sm-6 col-lg-3">
            <div class="stat-mini" style="background:rgba(16,185,129,0.06);border-color:rgba(16,185,129,0.12)">
                <div class="stat-mini-icon" style="background:rgba(16,185,129,0.15);color:var(--green)"><i class="fa-solid fa-user-tie"></i></div>
                <div>
                    <div style="font-size:14px;font-weight:700;color:var(--green)">@Model.ManagerName</div>
                    <div style="font-size:12px;color:var(--text-muted)">Depo Sorumlusu</div>
                </div>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.Phone))
    {
        <div class="col-sm-6 col-lg-3">
            <div class="stat-mini" style="background:rgba(245,158,11,0.06);border-color:rgba(245,158,11,0.12)">
                <div class="stat-mini-icon" style="background:rgba(245,158,11,0.15);color:var(--yellow)"><i class="fa-solid fa-phone"></i></div>
                <div>
                    <div style="font-size:14px;font-weight:700;color:var(--yellow)">@Model.Phone</div>
                    <div style="font-size:12px;color:var(--text-muted)">Telefon</div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Products Table -->
<div class="glass-card p-0" style="overflow:hidden">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--border-glass)">
        <div>
            <div style="font-size:15px;font-weight:700">Stok Envanteri</div>
            <div style="font-size:12px;color:var(--text-muted);margin-top:2px">Bu depodaki tum urunler ve stok seviyeleri</div>
        </div>
    </div>

    @if (!Model.ProductWarehouses.Any())
    {
        <div style="padding:60px 24px;text-align:center;color:var(--text-muted)">
            <i class="fa-solid fa-box-open" style="font-size:42px;opacity:0.2;margin-bottom:16px;display:block"></i>
            <div style="font-size:15px;font-weight:600;margin-bottom:6px">Bu depoda henuz urun yok</div>
            <div style="font-size:13px">Diger depolardan transfer yaparak stok ekleyebilirsiniz.</div>
        </div>
    }
    else
    {
        <div style="overflow-x:auto">
            <table class="nova-table">
                <thead>
                    <tr>
                        <th>Urun</th>
                        <th>Kategori</th>
                        <th>Raf / Bolum</th>
                        <th>Stok</th>
                        <th style="text-align:right">Islem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pw in Model.ProductWarehouses.OrderByDescending(x => x.Quantity))
                    {
                        var qtyClass = pw.Quantity == 0 ? "low" : pw.Quantity < 10 ? "mid" : "";
                        <tr class="product-row-hover">
                            <td>
                                <div style="font-weight:600;font-size:13px">@pw.Product?.Name</div>
                                <div style="font-size:11px;color:var(--text-muted);margin-top:2px">SKU: @(pw.Product?.SKU ?? "—")</div>
                            </td>
                            <td>
                                @if (pw.Product?.Category != null)
                                {
                                    <span class="badge-nova badge-purple">@pw.Product.Category.Name</span>
                                }
                                else { <span style="color:var(--text-muted);font-size:12px">—</span> }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(pw.Location))
                                {
                                    <span style="font-size:12px;color:var(--text-secondary)">
                                        <i class="fa-solid fa-map-pin" style="margin-right:4px;color:var(--accent-light);font-size:10px"></i>@pw.Location
                                    </span>
                                }
                                else { <span style="color:var(--text-muted);font-size:12px">—</span> }
                            </td>
                            <td><span class="qty-badge @qtyClass">@pw.Quantity adet</span></td>
                            <td style="text-align:right">
                                @if (allWarehouses.Any() && pw.Quantity > 0)
                                {
                                    var safeName = (pw.Product?.Name ?? "Urun").Replace("'", "\\'");
                                    <button class="btn-nova-outline"
                                            style="padding:6px 14px;font-size:12px"
                                            onclick="openTransfer(@pw.ProductId, '@safeName', @pw.Quantity)">
                                        <i class="fa-solid fa-arrow-right-arrow-left"></i> Transfer
                                    </button>
                                }
                                else if (!allWarehouses.Any())
                                {
                                    <span style="font-size:11px;color:var(--text-muted)">Hedef depo yok</span>
                                }
                                else
                                {
                                    <span style="font-size:11px;color:var(--text-muted)">Stok yok</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal Overlay -->
<div class="transfer-modal-overlay" id="transferOverlay">
    <div class="transfer-modal">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
            <div style="font-size:18px;font-weight:700">
                <i class="fa-solid fa-arrow-right-arrow-left" style="color:var(--accent);margin-right:8px"></i>
                Stok Transfer
            </div>
            <button onclick="closeTransfer()"
                    style="width:32px;height:32px;border-radius:8px;border:1px solid var(--border-glass);background:none;cursor:pointer;color:var(--text-muted);font-size:18px;display:flex;align-items:center;justify-content:center;line-height:1">
                ×
            </button>
        </div>

        <form method="post" action="/Warehouse/Transfer" id="transferForm">
            <input type="hidden" name="fromWarehouseId" value="@Model.Id" />
            <input type="hidden" name="productId" id="transferProductId" />

            <div class="mb-3">
                <label class="form-label-nova">Urun</label>
                <div id="transferProductName"
                     style="font-weight:600;font-size:14px;padding:10px 14px;background:rgba(99,102,241,0.06);border-radius:10px;border:1px solid rgba(99,102,241,0.12)">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label-nova">Kaynak Depo</label>
                <div style="font-size:13px;padding:10px 14px;background:rgba(0,0,0,0.03);border-radius:10px;border:1px solid var(--border-glass);color:var(--text-secondary)">
                    <i class="fa-solid fa-warehouse" style="margin-right:6px;color:var(--text-muted)"></i>
                    @Model.Name - @Model.City
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label-nova" for="toWarehouseId">Hedef Depo</label>
                <select name="toWarehouseId" id="toWarehouseId" class="form-nova" required>
                    <option value="">— Depo Secin —</option>
                    @foreach (var wh in allWarehouses)
                    {
                        <option value="@wh.Id">@wh.Name - @wh.City</option>
                    }
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label-nova" for="transferQty">
                    Miktar
                    <span id="maxQtyLabel" style="color:var(--text-muted);font-weight:400;margin-left:4px"></span>
                </label>
                <input type="number" name="quantity" id="transferQty"
                       class="form-nova" min="1" required
                       placeholder="Kac adet transfer edilsin?" />
            </div>

            <div style="display:flex;gap:10px">
                <button type="button" onclick="closeTransfer()"
                        class="btn-nova-outline" style="flex:1;justify-content:center">
                    Iptal
                </button>
                <button type="submit" id="transferSubmitBtn" class="btn-nova" style="flex:2;justify-content:center">
                    <i class="fa-solid fa-paper-plane"></i> Transferi Onayla
                </button>
            </div>
        </form>
    </div>
</div>