@{
    ViewData["Title"] = "Yeni Sipariş Oluştur";
    var products = ViewBag.Products as List<NovaStock.Web.Models.Product> ?? new List<NovaStock.Web.Models.Product>();
    var warehouses = ViewBag.Warehouses as List<NovaStock.Web.Models.Warehouse> ?? new List<NovaStock.Web.Models.Warehouse>();
    var suppliers = ViewBag.Suppliers as List<NovaStock.Web.Models.Supplier> ?? new List<NovaStock.Web.Models.Supplier>();
    var dealers = ViewBag.Dealers as List<NovaStock.Web.Models.ApplicationUser>;
}

<div class="page-header">
    <div>
        <h1><i class="fa-solid fa-cart-plus" style="color:var(--accent-light);margin-right:10px"></i>Yeni Sipariş Oluştur</h1>
        <div class="breadcrumb-nova">Stoktan ürün seçerek siparişinizi oluşturun</div>
    </div>
</div>

<div class="glass-card p-4">
    <form method="post" action="/Order/Create" id="orderForm">
        @Html.AntiForgeryToken()

        <!-- Üst Ayarlar -->
        <div class="row g-4 mb-4 pb-4" style="border-bottom:1px solid var(--border-glass)">
            @if (dealers != null)
            {
                <div class="col-md-4">
                    <label class="form-label-nova"><i class="fa-solid fa-users" style="color:var(--text-muted);margin-right:6px"></i>Bayi Seçimi (Sadece Admin)</label>
                    <select name="dealerId" class="form-nova" required>
                        <option value="">-- Lütfen Bayi Seçiniz --</option>
                        @foreach (var d in dealers)
                        {
                            <option value="@d.Id">@d.FullName - @d.CompanyName</option>
                        }
                    </select>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:6px">Siparişi oluşturacağınız bayiyi seçin.</div>
                </div>
            }
            <div class="col-md-@(dealers != null ? "4" : "6")">
                <label class="form-label-nova"><i class="fa-solid fa-warehouse" style="color:var(--text-muted);margin-right:6px"></i>Sevk Deposu Seçimi</label>
                <select name="warehouseId" class="form-nova" required>
                    <option value="">-- Lütfen Depo Seçiniz --</option>
                    @foreach(var w in warehouses)
                    {
                        <option value="@w.Id">@w.Name - @w.City</option>
                    }
                </select>
                <div style="font-size:11px;color:var(--text-muted);margin-top:6px">Siparişin çıkacağı ana depoyu belirleyin.</div>
            </div>
            <div class="col-md-@(dealers != null ? "4" : "6")">
                <label class="form-label-nova"><i class="fa-solid fa-note-sticky" style="color:var(--text-muted);margin-right:6px"></i>Sipariş Notu (Opsiyonel)</label>
                <input type="text" name="notes" class="form-nova" placeholder="Örn: Hafta içi teslim edilsin." />
            </div>
        </div>

        <!-- Ürün Filtresi -->
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label-nova"><i class="fa-solid fa-filter" style="color:var(--text-muted);margin-right:6px"></i>Tedarikçiye Göre Filtrele</label>
                <select id="supplierFilter" class="form-nova" onchange="filterProductsBySupplier()">
                    <option value="">Tüm Ürünler</option>
                    @foreach (var s in suppliers)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
            </div>
        </div>

        <!-- Ürün Listesi -->
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
            <div style="font-size:15px;font-weight:600;color:var(--accent)"><i class="fa-solid fa-box-open" style="margin-right:8px"></i>Sipariş Kalemleri</div>
            <button type="button" class="btn-nova-outline" onclick="addRow()"><i class="fa-solid fa-plus"></i> Ürün Satırı Ekle</button>
        </div>

        <div style="overflow-x:auto">
            <table class="nova-table" id="itemsTable">
                <thead>
                    <tr>
                        <th style="width:50%">Ürün Seçimi</th>
                        <th style="width:20%">Adet</th>
                        <th style="width:20%">Stok Durumu</th>
                        <th style="width:10%;text-align:right">İşlem</th>
                    </tr>
                </thead>
                <tbody id="itemsTbody">
                    <!-- Dinamik satırlar buraya eklenecek -->
                </tbody>
            </table>
        </div>

        <div style="display:flex;justify-content:flex-end;margin-top:24px">
            <button type="submit" class="btn-nova" style="padding:12px 24px;font-size:14px">
                <i class="fa-solid fa-paper-plane"></i> Siparişi Tamamla
            </button>
        </div>
    </form>
</div>

<!-- Gizli Şablon (Satır Ekleme İçin) -->
<template id="rowTemplate">
    <tr class="item-row">
        <td>
            <select name="productIds" class="form-nova product-select" required onchange="updateStock(this)">
                <option value="">-- Ürün Seçiniz --</option>
            </select>
        </td>
        <td>
            <input type="number" name="quantities" class="form-nova" min="1" value="1" required style="width:100px" />
        </td>
        <td>
            <div class="stock-info badge-nova badge-gray">Seçim Bekleniyor</div>
        </td>
        <td style="text-align:right">
            <button type="button" class="btn-danger-nova" onclick="this.closest('tr').remove()" title="Satırı Sil">
                <i class="fa-solid fa-trash-can"></i>
            </button>
        </td>
    </tr>
</template>

@section Scripts {
    <script>
        const allProducts = [
            @foreach (var p in products)
            {
                @: { id: "@p.Id", text: "@Html.Raw($"{p.SKU} - {p.Name} ({p.BasePrice.ToString("N2")} ₺)")", stock: @p.StockCount, critical: @p.CriticalStockLevel, supplierId: "@(p.SupplierId?.ToString() ?? "")" },
            }
        ];

        // Sayfa yüklendiğinde varsayılan 1 satır ekle
        document.addEventListener('DOMContentLoaded', () => {
            addRow();
        });

        function filterProductsBySupplier() {
            const supplierId = document.getElementById('supplierFilter').value;

            document.querySelectorAll('select.product-select').forEach(select => {
                const currentValue = select.value;
                select.innerHTML = '<option value="">-- Ürün Seçiniz --</option>';

                allProducts.forEach(p => {
                    if (!supplierId || p.supplierId === supplierId || p.supplierId === "") {
                        const opt = document.createElement('option');
                        opt.value = p.id;
                        opt.textContent = p.text;
                        opt.setAttribute('data-stock', p.stock);
                        opt.setAttribute('data-critical', p.critical);
                        if (p.id === currentValue) {
                            opt.selected = true;
                        }
                        select.appendChild(opt);
                    }
                });
                updateStock(select);
            });
        }

        function getFilteredProductOptions() {
            const supplierId = document.getElementById('supplierFilter').value;
            let html = '<option value="">-- Ürün Seçiniz --</option>';
            allProducts.forEach(p => {
                if (!supplierId || p.supplierId === supplierId || p.supplierId === "") {
                    html += `<option value="${p.id}" data-stock="${p.stock}" data-critical="${p.critical}">${p.text}</option>`;
                }
            });
            return html;
        }

        function addRow() {
            const template = document.getElementById('rowTemplate');
            const tbody = document.getElementById('itemsTbody');
            const clone = template.content.cloneNode(true);
            
            // Satır eklendikten sonra ürün listesini filtreye göre doldur
            const newSelect = clone.querySelector('select.product-select');
            newSelect.innerHTML = getFilteredProductOptions();

            tbody.appendChild(clone);
        }

        function updateStock(selectElem) {
            const tr = selectElem.closest('tr');
            const stockInfo = tr.querySelector('.stock-info');
            const option = selectElem.options[selectElem.selectedIndex];

            if(!option || !option.value) {
                stockInfo.className = 'stock-info badge-nova badge-gray';
                stockInfo.innerHTML = 'Seçim Bekleniyor';
                return;
            }

            const stock = parseInt(option.getAttribute('data-stock'));
            const critical = parseInt(option.getAttribute('data-critical'));

            stockInfo.innerHTML = `${stock} Adet`;

            if(stock <= 0) {
                stockInfo.className = 'stock-info badge-nova badge-red';
                stockInfo.innerHTML = 'Stok Yok!';
            } else if(stock <= critical) {
                stockInfo.className = 'stock-info badge-nova badge-yellow';
            } else {
                stockInfo.className = 'stock-info badge-nova badge-green';
            }
        }
    </script>
}
