@model NovaStock.Web.ViewModels.BulkOrderResultViewModel
@{
    ViewData["Title"] = "Toplu Sipariş Sonucu";
}

<div class="page-header">
    <div>
        <h1><i class="fa-solid fa-file-excel" style="color:var(--green);margin-right:10px"></i>Toplu Sipariş Kontrolü</h1>
        <div class="breadcrumb-nova">Excel yükleme sonucu</div>
    </div>
    <div style="display:flex;gap:10px">
        <a href="/Order/BulkOrderTemplate" class="btn-nova-outline">
            <i class="fa-solid fa-download"></i> Şablonu İndir
        </a>
        <a href="/Order" class="btn-nova-outline"><i class="fa-solid fa-arrow-left"></i> Siparişlerim</a>
    </div>
</div>

<!-- Özet -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="glass-card p-4" style="border-top:3px solid var(--green)">
            <div style="font-size:12px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px">Onaylanacak Ürün</div>
            <div style="font-size:32px;font-weight:800;color:var(--green)">@Model.ValidCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-card p-4" style="border-top:3px solid var(--red)">
            <div style="font-size:12px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px">Sorunlu Satır</div>
            <div style="font-size:32px;font-weight:800;color:var(--red)">@Model.InvalidCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-card p-4" style="border-top:3px solid var(--yellow)">
            <div style="font-size:12px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;margin-bottom:8px">Excel Hatası</div>
            <div style="font-size:32px;font-weight:800;color:var(--yellow)">@Model.ExcelErrors.Count</div>
        </div>
    </div>
</div>

@if (Model.ExcelErrors.Any())
{
    <div class="glass-card mb-4 p-4" style="border-top:3px solid var(--red)">
        <div style="font-size:14px;font-weight:700;color:var(--red);margin-bottom:14px">
            <i class="fa-solid fa-triangle-exclamation" style="margin-right:6px"></i>Excel Hataları
        </div>
        <ul style="font-size:13px;color:var(--text-muted);margin:0;padding-left:20px;line-height:2.2">
            @foreach (var err in Model.ExcelErrors)
            {
                <li style="color:var(--red)">@err</li>
            }
        </ul>
    </div>
}

@if (Model.Items.Any())
{
    <div class="glass-card">
        <div style="padding:18px 20px;border-bottom:1px solid var(--border-glass);font-size:15px;font-weight:600">
            <i class="fa-solid fa-list-check" style="color:var(--accent-light);margin-right:8px"></i>Ürün Kontrol Sonuçları
        </div>
        <div style="overflow-x:auto">
            <table class="nova-table">
                <thead>
                    <tr>
                        <th>SKU</th>
                        <th>Ürün Adı</th>
                        <th style="text-align:center">Talep Edilen</th>
                        <th style="text-align:center">Mevcut Stok</th>
                        <th style="text-align:right">Birim Fiyat</th>
                        <th style="text-align:right">Satır Toplamı</th>
                        <th style="text-align:center">Durum</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr style="@(item.IsOk ? "" : "background:rgba(239,68,68,.04)")">
                        <td style="font-family:monospace;font-size:12px;color:var(--text-muted)">@item.SKU</td>
                        <td style="font-weight:600">@item.ProductName</td>
                        <td style="text-align:center">@item.Requested</td>
                        <td style="text-align:center;color:@(item.Available >= item.Requested ? "var(--green)" : "var(--red)");font-weight:700">
                            @item.Available
                        </td>
                        <td style="text-align:right;font-family:monospace">@item.UnitPrice.ToString("N2") ₺</td>
                        <td style="text-align:right;font-weight:700">@((item.UnitPrice * item.Requested).ToString("N2")) ₺</td>
                        <td style="text-align:center">
                            @if (item.IsOk)
                            {
                                <span class="badge-nova badge-green"><i class="fa-solid fa-check"></i> Tamam</span>
                            }
                            else
                            {
                                <span class="badge-nova badge-red"><i class="fa-solid fa-xmark"></i> Yetersiz Stok</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr style="background:var(--bg-body)">
                        <td colspan="5" style="text-align:right;font-weight:700;padding:14px">Genel Toplam:</td>
                        <td style="text-align:right;font-weight:800;font-size:16px;color:var(--accent)">
                            @Model.Items.Where(i => i.IsOk).Sum(i => i.UnitPrice * i.Requested).ToString("N2") ₺
                        </td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        @if (Model.CanProceed)
        {
            <div style="padding:20px;border-top:1px solid var(--border-glass);display:flex;justify-content:flex-end;gap:12px">
                <a href="/Order/Create" class="btn-nova">
                    <i class="fa-solid fa-shopping-cart"></i> @Model.ValidCount Ürün için Sipariş Ver
                </a>
            </div>
        }
    </div>
}
