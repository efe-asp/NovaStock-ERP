@model IEnumerable<NovaStock.Web.Models.Order>
@{
    ViewData["Title"] = "Siparişler";
}

<div class="page-header">
    <div>
        <h1><i class="fa-solid fa-cart-shopping" style="color:var(--yellow);margin-right:10px"></i>Sipariş Yönetimi</h1>
        <div class="breadcrumb-nova">Toplam @Model.Count() sipariş</div>
    </div>
    @if (User.IsInRole("Dealer") || User.IsInRole("Admin"))
    {
        <a href="/Order/Create" class="btn-nova"><i class="fa-solid fa-plus"></i> Yeni Sipariş</a>
    }
</div>

<div class="glass-card">
    <div style="overflow-x:auto">
        <table class="nova-table">
            <thead><tr>
                <th>SİPARİŞ NO</th><th>BAYİ</th><th>TUTAR</th><th>İNDİRİM</th>
                <th>TOPLAM</th><th>DEPO</th><th>DURUM</th><th>TARİH</th><th>İŞLEM</th>
            </tr></thead>
            <tbody>
            @foreach (var o in Model)
            {
                var badgeClass = o.Status switch {
                    NovaStock.Web.Models.OrderStatus.Pending   => "badge-yellow",
                    NovaStock.Web.Models.OrderStatus.Approved  => "badge-cyan",
                    NovaStock.Web.Models.OrderStatus.Shipped   => "badge-purple",
                    NovaStock.Web.Models.OrderStatus.Delivered => "badge-green",
                    NovaStock.Web.Models.OrderStatus.Cancelled => "badge-red",
                    _ => "badge-gray"
                };
                var statusTr = o.Status switch {
                    NovaStock.Web.Models.OrderStatus.Pending   => "Bekliyor",
                    NovaStock.Web.Models.OrderStatus.Approved  => "Onaylandı",
                    NovaStock.Web.Models.OrderStatus.Shipped   => "Kargoda",
                    NovaStock.Web.Models.OrderStatus.Delivered => "Teslim",
                    NovaStock.Web.Models.OrderStatus.Cancelled => "İptal",
                    _ => o.Status.ToString()
                };

                <tr>
                    <td style="font-family:monospace;font-size:12px;color:var(--accent-light)">@o.OrderNumber</td>
                    <td>
                        <div style="font-weight:600;font-size:13px">@o.Dealer?.FullName</div>
                        <div style="font-size:11px;color:var(--text-muted)">@o.Dealer?.CompanyName</div>
                    </td>
                    <td style="color:var(--text-secondary)">@o.SubTotal.ToString("N2") ₺</td>
                    <td style="color:var(--red)">-@o.DiscountAmount.ToString("N2") ₺</td>
                    <td style="font-weight:700;color:var(--green)">@o.Total.ToString("N2") ₺</td>
                    <td style="font-size:12px;color:var(--text-muted)">@(o.Warehouse?.City ?? "-")</td>
                    <td><span class="badge-nova @badgeClass">@statusTr</span></td>
                    <td style="font-size:12px;color:var(--text-muted)">@o.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <a href="/Order/Detail/@o.Id" class="btn-nova" style="padding:5px 10px;font-size:11px">
                                <i class="fa-solid fa-eye"></i>
                            </a>
                            <a href="/Order/DownloadInvoice/@o.Id" class="btn-nova-outline" style="padding:5px 10px;font-size:11px">
                                <i class="fa-solid fa-file-pdf"></i>
                            </a>
                            @if (User.IsInRole("Admin") && o.Status == NovaStock.Web.Models.OrderStatus.Pending)
                            {
                                <form method="post" action="/Order/Approve/@o.Id" onsubmit="return confirm('Bu siparişi onaylamak istediğinize emin misiniz?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-nova" style="padding:5px 10px;font-size:11px;background:linear-gradient(135deg,var(--green),#059669)" title="Onayla">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                </form>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <form method="post" action="/Order/Delete/@o.Id" onsubmit="return confirm('Bu siparişi tamamen silmek istediğinize emin misiniz? (Stoklar iade edilecektir)')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-nova" style="padding:5px 10px;font-size:11px;background:linear-gradient(135deg,var(--red),#b91c1c)" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="9" style="text-align:center;padding:50px;color:var(--text-muted)">
                    <i class="fa-solid fa-cart-shopping" style="font-size:32px;display:block;margin-bottom:12px;opacity:0.3"></i>
                    Henüz sipariş bulunmuyor.
                </td></tr>
            }
            </tbody>
        </table>
    </div>
</div>
