            <div class="accent-swatches">
                <div class="accent-swatch" data-color="#6366f1" style="background:#6366f1" onclick="applyAccent('#6366f1')" title="İndigo"></div>
                <div class="accent-swatch" data-color="#0ea5e9" style="background:#0ea5e9" onclick="applyAccent('#0ea5e9')" title="Mavi"></div>
                <div class="accent-swatch" data-color="#10b981" style="background:#10b981" onclick="applyAccent('#10b981')" title="Yeşil"></div>
                <div class="accent-swatch" data-color="#f59e0b" style="background:#f59e0b" onclick="applyAccent('#f59e0b')" title="Turuncu"></div>
                <div class="accent-swatch" data-color="#ef4444" style="background:#ef4444" onclick="applyAccent('#ef4444')" title="Kırmızı"></div>
                <div class="accent-swatch" data-color="#ec4899" style="background:#ec4899" onclick="applyAccent('#ec4899')" title="Pembe"></div>
                <div class="accent-swatch" data-color="#8b5cf6" style="background:#8b5cf6" onclick="applyAccent('#8b5cf6')" title="Mor"></div>
            </div>
