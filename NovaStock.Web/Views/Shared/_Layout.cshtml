            <div id="teamLink" style="display:none">
                <a href="/Dealer/TeamManagement" class="quick-link"><i class="fa-solid fa-users-gear"></i> Ekip Yönetimi</a>
            </div>
            <div id="adminLinks" style="display:none">
                <a href="/Dealer" class="quick-link"><i class="fa-solid fa-users"></i> Tüm Bayiler</a>
                <a href="/Settings" class="quick-link"><i class="fa-solid fa-gear"></i> Sistem Ayarları</a>
                <a href="/Audit" class="quick-link"><i class="fa-solid fa-shield-halved"></i> Denetim Günlüğü</a>
            </div>
        </div>
    </div>
    <!-- Profil Panel Overlay -->
    <div id="profileOverlay" style="display:none;position:fixed;inset:0;z-index:1999" onclick="closeProfilePanel()"></div>

    <!-- ── Top Navbar ──────────────────────────────────────────────────────── -->
    <header class="top-navbar">
        <button class="navbar-action-btn d-lg-none" id="sidebarToggle">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="navbar-page-title">
            @ViewData["Title"] <span>/ NovaStock ERP</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
            <div id="realtime-indicator" style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted)">
                <span id="connection-dot" style="width:8px;height:8px;border-radius:50%;background:var(--text-muted);display:inline-block"></span>
                <span id="connection-label">Bağlanıyor...</span>
            </div>
            <a href="/Product/ExportExcel" class="navbar-action-btn" title="Excel İndir">
                <i class="fa-solid fa-file-excel"></i>
            </a>
            <div class="navbar-action-btn" id="notifBtn" title="Bildirimler" onclick="toggleNotifDropdown()">
                <i class="fa-solid fa-bell"></i>
                <span class="notif-dot" id="notifDot" style="display:none; text-align:center; color:#fff; font-size:8px; line-height:10px; font-weight:bold; width:12px; height:12px; top:4px; right:4px;"></span>
            </div>
        </div>

        <!-- Notification Dropdown -->
        <div id="notifDropdown" class="notif-dropdown">
            <div class="notif-header">
                <span>Bildirimler</span>
                <button onclick="markAllAsRead(event)"><i class="fa-solid fa-check-double"></i> Tümünü Okundu İşaretle</button>
            </div>
            <div class="notif-body" id="notifList">
                <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px">Yükleniyor...</div>
            </div>
        </div>
    </header>

    <!-- ── SignalR Toast Container ─────────────────────────────────────────── -->
    <div id="toast-container"></div>

    <!-- ── Alert Messages ─────────────────────────────────────────────────── -->
    <div class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert-nova alert-success-nova mb-4" id="tempAlert">
                <i class="fa-solid fa-circle-check"></i>
                @TempData["Success"]
                <button onclick="this.parentElement.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer">×</button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-nova alert-danger-nova mb-4" id="tempAlert">
                <i class="fa-solid fa-triangle-exclamation"></i>
                @TempData["Error"]
                <button onclick="this.parentElement.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer">×</button>
            </div>
        }

        @RenderBody()
    </div>

    <!-- ── Scripts ─────────────────────────────────────────────────────────── -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <!-- ── Komut Paleti (Ctrl+K) ─────────────────────────────────────────────── -->
    <div id="cmdPaletteOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;display:none;align-items:flex-start;justify-content:center;padding-top:80px" onclick="closePalette(event)">
        <div id="cmdPalette" style="background:#fff;border-radius:16px;width:100%;max-width:560px;box-shadow:0 20px 60px rgba(0,0,0,0.25);overflow:hidden">
            <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid var(--border-glass)">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted)"></i>
                <input id="cmdInput" type="text" placeholder="Bir sayfa veya komut arayın..." autocomplete="off"
                       style="flex:1;border:none;outline:none;font-size:15px;font-family:inherit;color:var(--text-primary);background:transparent"
                       oninput="filterCommands(this.value)" onkeydown="handleKey(event)">
                <kbd style="font-size:11px;background:var(--border-glass);padding:3px 7px;border-radius:6px;color:var(--text-muted)">ESC</kbd>
            </div>
            <ul id="cmdList" style="list-style:none;padding:8px 0;max-height:360px;overflow-y:auto;margin:0"></ul>
        </div>
    </div>

    <script>
        // ── Sidebar Toggle (Mobile) ─────────────────────────────────────────
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('open');
        });

        // ── Auto-dismiss alerts ─────────────────────────────────────────────
        setTimeout(() => {
            document.getElementById('tempAlert')?.remove();
        }, 5000);

        // ── Toast Factory ───────────────────────────────────────────────────
        function showToast(type, icon, title, message, time) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `nova-toast ${type}`;
            toast.innerHTML = `
                <div class="toast-icon"><i class="${icon}"></i></div>
                <div class="toast-body">
                    <div class="toast-title">${title}</div>
                    <div class="toast-msg">${message}</div>
                </div>
                <div class="toast-time">${time}</div>`;
            container.appendChild(toast);
            // Ses efekti (basit beep)
            try {
                const ctx = new AudioContext();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain); gain.connect(ctx.destination);
                osc.frequency.value = type === 'order' ? 880 : 440;
                gain.gain.setValueAtTime(0.1, ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
                osc.start(); osc.stop(ctx.currentTime + 0.4);
            } catch(e) {}
            setTimeout(() => toast.remove(), 6000);
        }

        // ── Notifications (UI & SignalR) ────────────────────────────────────
        let unreadCount = 0;

        async function fetchNotifications() {
            try {
                const res = await fetch('/Notification/GetLatest');
                const data = await res.json();
                if(data.success) {
                    unreadCount = data.unreadCount;
                    updateNotifDot();
                    renderNotifications(data.notifications);
                }
            } catch (e) { console.error(e); }
        }

        function updateNotifDot() {
            const dot = document.getElementById('notifDot');
            if(unreadCount > 0) {
                dot.style.display = 'block';
                dot.textContent = unreadCount > 9 ? '9+' : unreadCount;
            } else {
                dot.style.display = 'none';
            }
        }

        function renderNotifications(list) {
            const container = document.getElementById('notifList');
            if(list.length === 0) {
                container.innerHTML = '<div style="padding:30px 20px;text-align:center;color:var(--text-muted);font-size:13px"><i class="fa-regular fa-bell-slash" style="font-size:24px;margin-bottom:10px;opacity:0.5;display:block"></i>Yeni bildirim yok.</div>';
                return;
            }
            container.innerHTML = list.map(n => `
                <div class="notif-item ${n.type} ${n.isRead ? '' : 'unread'}" onclick="markAsRead(${n.id}, this)">
                    <div class="notif-item-icon"><i class="fa-solid ${n.iconClass || 'fa-bell'}"></i></div>
                    <div class="notif-item-content">
                        <div class="notif-item-title">${n.title}</div>
                        <div class="notif-item-msg">${n.message}</div>
                        <div class="notif-item-time">${n.timeAgo}</div>
                    </div>
                </div>
            `).join('');
        }

        function toggleNotifDropdown() {
            const dropdown = document.getElementById('notifDropdown');
            dropdown.style.display = dropdown.style.display === 'flex' ? 'none' : 'flex';
        }

        async function markAsRead(id, el) {
            if(!el.classList.contains('unread')) return;
            try {
                await fetch('/Notification/MarkAsRead?id=' + id, { method: 'POST' });
                el.classList.remove('unread');
                unreadCount = Math.max(0, unreadCount - 1);
                updateNotifDot();
            } catch (e) {}
        }

        async function markAllAsRead(e) {
            if (e) e.stopPropagation();
            try {
                await fetch('/Notification/MarkAllAsRead', { method: 'POST' });
                unreadCount = 0;
                updateNotifDot();
                document.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
            } catch (e) {}
        }

        document.addEventListener('click', (e) => {
            const btn = document.getElementById('notifBtn');
            const dropdown = document.getElementById('notifDropdown');
            if(btn && dropdown && !btn.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.style.display = 'none';
            }
        });

        // ── Ticket rozeti güncelleme ──────────────────────────────────────────
        async function fetchTicketCounts() {
            try {
                const res  = await fetch('/Notification/GetCounts');
                const data = await res.json();
                const badge = document.getElementById('adminTicketBadge');
                if (badge) {
                    if (data.openTicketCount > 0) {
                        badge.textContent = data.openTicketCount > 9 ? '9+' : data.openTicketCount;
                        badge.style.display = 'inline-flex';
                    } else {
                        badge.style.display = 'none';
                    }
                }
                // Bayi: yanıtlanan talep rozeti (sidebar'da varsa)
                const dealerBadge = document.getElementById('dealerTicketBadge');
                if (dealerBadge) {
                    if (data.openTicketCount > 0) {
                        dealerBadge.textContent = data.openTicketCount > 9 ? '9+' : data.openTicketCount;
                        dealerBadge.style.display = 'inline-flex';
                    } else {
                        dealerBadge.style.display = 'none';
                    }
                }
            } catch (e) { console.error(e); }
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetchNotifications();
            fetchTicketCounts();
            initThemeFromStorage();
            loadProfileData();
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveOrderNotification", data => {
            fetchNotifications(); // UI'ı yenile
            showToast('order', 'fa-solid fa-cart-check',
                'Yeni Sipariş!',
                `${data.dealerName} – ${data.total} ₺`,
                data.timestamp);
        });

        connection.on("ReceiveStockAlert", data => {
            fetchNotifications(); // UI'ı yenile
            showToast('stock', 'fa-solid fa-triangle-exclamation',
                '⚠️ Kritik Stok!',
                `${data.productName}: ${data.remainingStock} adet kaldı`,
                data.timestamp);
        });

        // ── Destek Talebi Bildirimi (Admin tarafı) ───────────────────────────
        connection.on("ReceiveSupportTicketNotification", data => {
            fetchNotifications();
            fetchTicketCounts();
            showToast('support', 'fa-solid fa-headset',
                'Yeni Destek Talebi',
                `${data.dealerName}: ${data.subject}`,
                data.timestamp);
        });

        // ── Bayi Bildirimi (Bayi tarafı) ─────────────────────────────────────
        connection.on("ReceiveDealerNotification", data => {
            fetchNotifications();
            fetchTicketCounts();
            showToast('support', 'fa-solid fa-headset',
                'Destek Talebiniz Güncellendi',
                data.message,
                data.timestamp);
        });

        async function startSignalR() {
            const dot   = document.getElementById('connection-dot');
            const label = document.getElementById('connection-label');
            try {
                await connection.start();
                dot.style.background   = 'var(--green)';
                label.textContent      = 'Canlı';
                label.style.color      = 'var(--green)';
            } catch (err) {
                dot.style.background   = 'var(--red)';
                label.textContent      = 'Bağlantı yok';
            }
        }
        startSignalR();

        // ── Profil Panel ─────────────────────────────────────────────────────────
        let _profData = null;
        let _currentTheme = localStorage.getItem('nova_theme') || 'light';
        let _currentAccent = localStorage.getItem('nova_accent') || '#6366f1';

        function initThemeFromStorage() {
            const t = localStorage.getItem('nova_theme') || 'light';
            const a = localStorage.getItem('nova_accent') || '#6366f1';
            document.documentElement.setAttribute('data-theme', t);
            applyAccentColor(a, false);
        }

        function toggleProfilePanel() {
            const panel   = document.getElementById('profilePanel');
            const overlay = document.getElementById('profileOverlay');
            const isOpen  = panel.style.display === 'flex';
            if (isOpen) {
                closeProfilePanel();
            } else {
                panel.style.display = 'flex';
                overlay.style.display = 'block';
            }
        }

        function closeProfilePanel() {
            document.getElementById('profilePanel').style.display = 'none';
            document.getElementById('profileOverlay').style.display = 'none';
        }

        function switchProfTab(name) {
            document.querySelectorAll('.prof-tab').forEach((t, i) => {
                const tabs = ['profil', 'guvenlik', 'tema', 'hizli'];
                t.classList.toggle('active', tabs[i] === name);
            });
            document.querySelectorAll('.prof-tab-content').forEach(c => c.classList.remove('active'));
            const target = document.getElementById('tab-' + name);
            if (target) target.classList.add('active');
        }

        async function loadProfileData() {
            try {
                const res  = await fetch('/Account/GetProfileInfo');
                const data = await res.json();
                _profData  = data;

                // Header
                const avatar = data.fullName ? data.fullName[0].toUpperCase() : '?';
                const panelAvatar = document.getElementById('panelAvatar');
                const sidebarAvatar = document.getElementById('sidebarAvatar');
                if (panelAvatar) panelAvatar.textContent = avatar;
                if (sidebarAvatar) sidebarAvatar.textContent = avatar;

                const panelName  = document.getElementById('panelName');
                const panelEmail = document.getElementById('panelEmail');
                if (panelName)  panelName.textContent  = data.fullName || '';
                if (panelEmail) panelEmail.textContent = data.email || '';

                // Rol rozeti
                const roleBadge = document.getElementById('panelRoleBadge');
                if (roleBadge) {
                    const color = data.role === 'Admin' ? 'badge-red' :
                                  data.role === 'Dealer' ? 'badge-purple' :
                                  data.role === 'DealerFinance' ? 'badge-green' : 'badge-cyan';
                    roleBadge.innerHTML = `<span class="badge-nova ${color}" style="font-size:10px">${data.roleLabel}</span>`;
                }

                // Profil sekmesi inputları
                const fn = document.getElementById('profFullName');
                const ph = document.getElementById('profPhone');
                const ad = document.getElementById('profAddress');
                if (fn) fn.value = data.fullName || '';
                if (ph) ph.value = data.phone    || '';
                if (ad) ad.value = data.address  || '';

                // Tema
                updateThemeButtons(_currentTheme);
                updateSwatchActive(_currentAccent);

                // Bayi bilgisi (Hızlı sekme)
                const dealerPanel = document.getElementById('dealerInfoPanel');
                const teamLink    = document.getElementById('teamLink');
                const adminLinks  = document.getElementById('adminLinks');

                if (data.isAdmin) {
                    if (adminLinks) adminLinks.style.display = 'block';
                } else if (data.isMainDealer) {
                    if (dealerPanel) dealerPanel.style.display = 'block';
                    if (teamLink)    teamLink.style.display    = 'block';
                    const tierBadge = document.getElementById('panelTierBadge');
                    const tierColors = { Gold: 'badge-gold', Silver: 'badge-silver', Bronze: 'badge-bronze' };
                    if (tierBadge) tierBadge.innerHTML = `<span class="badge-nova ${tierColors[data.tier] || 'badge-gray'}">${data.tier}</span>`;
                    const panelComp = document.getElementById('panelCompany');
                    if (panelComp) panelComp.textContent = data.companyName || '';
                }

                // Kullanıcının kaydedilmiş temasını uygula (DB'den al)
                if (data.themeMode && !localStorage.getItem('nova_theme_synced')) {
                    localStorage.setItem('nova_theme', data.themeMode);
                    localStorage.setItem('nova_accent', data.accentColor || '#6366f1');
                    localStorage.setItem('nova_theme_synced', '1');
                    applyTheme(data.themeMode, false);
                    applyAccentColor(data.accentColor || '#6366f1', false);
                }
            } catch(e) { console.warn('Profil yüklenemedi', e); }
        }

        async function saveProfile() {
            const fn = document.getElementById('profFullName')?.value || '';
            const ph = document.getElementById('profPhone')?.value || '';
            const ad = document.getElementById('profAddress')?.value || '';
            const msg = document.getElementById('profMsg');

            try {
                const res  = await fetch('/Account/UpdateProfile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ fullName: fn, phoneNumber: ph, address: ad })
                });
                const data = await res.json();
                showProfMsg(msg, data.success, data.message);
                if (data.success) {
                    const panelName = document.getElementById('panelName');
                    if (panelName) panelName.textContent = fn;
                    const sidebarAvatar = document.getElementById('sidebarAvatar');
                    const panelAvatar   = document.getElementById('panelAvatar');
                    if (fn && sidebarAvatar) sidebarAvatar.textContent = fn[0].toUpperCase();
                    if (fn && panelAvatar)   panelAvatar.textContent   = fn[0].toUpperCase();
                }
            } catch(e) { showProfMsg(msg, false, 'Bağlantı hatası.'); }
        }

        async function changePassword() {
            const cur = document.getElementById('pwCurrent')?.value || '';
            const nw  = document.getElementById('pwNew')?.value || '';
            const cnf = document.getElementById('pwConfirm')?.value || '';
            const msg = document.getElementById('pwMsg');

            if (nw !== cnf) { showProfMsg(msg, false, 'Şifreler eşleşmiyor.'); return; }
            if (nw.length < 6) { showProfMsg(msg, false, 'Şifre en az 6 karakter olmalı.'); return; }

            try {
                const res  = await fetch('/Account/ChangePassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ currentPassword: cur, newPassword: nw, confirmNewPassword: cnf })
                });
                const data = await res.json();
                showProfMsg(msg, data.success, data.message);
                if (data.success) {
                    document.getElementById('pwCurrent').value = '';
                    document.getElementById('pwNew').value     = '';
                    document.getElementById('pwConfirm').value = '';
                }
            } catch(e) { showProfMsg(msg, false, 'Bağlantı hatası.'); }
        }

        function applyTheme(mode, save = true) {
            _currentTheme = mode;
            document.documentElement.setAttribute('data-theme', mode);
            localStorage.setItem('nova_theme', mode);
            updateThemeButtons(mode);
            if (save) saveThemeToServer();
        }

        function updateThemeButtons(mode) {
            const btnL = document.getElementById('btnLight');
            const btnD = document.getElementById('btnDark');
            if (!btnL || !btnD) return;
            btnL.style.borderColor = mode === 'light' ? 'var(--accent)' : 'var(--border-glass)';
            btnL.style.color       = mode === 'light' ? 'var(--accent)' : 'var(--text-primary)';
            btnD.style.borderColor = mode === 'dark'  ? 'var(--accent)' : 'var(--border-glass)';
            btnD.style.color       = mode === 'dark'  ? 'var(--accent)' : 'var(--text-primary)';
        }

        function applyAccent(hex, save = true) {
            _currentAccent = hex;
            applyAccentColor(hex, save);
        }

        function applyAccentColor(hex, save = true) {
            // hex to RGB for glow
            const r = parseInt(hex.slice(1,3),16);
            const g = parseInt(hex.slice(3,5),16);
            const b = parseInt(hex.slice(5,7),16);
            const darker = shadeColor(hex, -15);
            document.documentElement.style.setProperty('--accent', hex);
            document.documentElement.style.setProperty('--accent-light', darker);
            document.documentElement.style.setProperty('--accent-glow', `rgba(${r},${g},${b},0.25)`);
            localStorage.setItem('nova_accent', hex);
            updateSwatchActive(hex);
            if (save) saveThemeToServer();
        }

        function shadeColor(color, percent) {
            let R = parseInt(color.slice(1,3),16);
            let G = parseInt(color.slice(3,5),16);
            let B = parseInt(color.slice(5,7),16);
            R = Math.min(255, Math.max(0, R + (R * percent / 100)));
            G = Math.min(255, Math.max(0, G + (G * percent / 100)));
            B = Math.min(255, Math.max(0, B + (B * percent / 100)));
            return '#' + [R,G,B].map(v => Math.round(v).toString(16).padStart(2,'0')).join('');
        }

        function updateSwatchActive(hex) {
            document.querySelectorAll('.accent-swatch').forEach(s => {
                s.classList.toggle('active', s.dataset.color.toLowerCase() === hex.toLowerCase());
            });
        }

        async function saveThemeToServer() {
            try {
                await fetch('/Account/SaveThemePreference', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getAntiForgeryToken() },
                    body: JSON.stringify({ themeMode: _currentTheme, accentColor: _currentAccent })
                });
            } catch(e) {}
        }

        function showProfMsg(el, ok, msg) {
            if (!el) return;
            el.className = 'prof-msg ' + (ok ? 'ok' : 'err');
            el.textContent = msg;
            el.style.display = 'block';
            setTimeout(() => { el.style.display = 'none'; }, 4000);
        }

        function getAntiForgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        }

        // ── Komut Paleti (Ctrl+K) ──────────────────────────────────────────────
        const COMMANDS = [
            { icon: 'fa-gauge-high',       label: 'Dashboard',         sub: 'Ana sayfa',                 url: '/' },
            { icon: 'fa-box-open',         label: 'Ürünler',           sub: 'Ürün yönetimi',             url: '/Product' },
            { icon: 'fa-plus',             label: 'Yeni Ürün Ekle',    sub: 'Ürün oluştur',              url: '/Product/Create' },
            { icon: 'fa-cart-shopping',    label: 'Siparişler',        sub: 'Sipariş yönetimi',          url: '/Order' },
            { icon: 'fa-users',            label: 'Bayiler',           sub: 'Bayi listesi',              url: '/Dealer' },
            { icon: 'fa-truck-ramp-box',   label: 'Tedarikçiler',      sub: 'Tedarikçi yönetimi',        url: '/Supplier' },
            { icon: 'fa-boxes-stacked',    label: 'Mal Kabul',         sub: 'Stok artır',                url: '/Supplier/Purchase' },
            { icon: 'fa-tag',              label: 'Kampanyalar',       sub: 'Fiyat politikası',          url: '/Promotion' },
            { icon: 'fa-warehouse',        label: 'Depolar',           sub: 'Depo yönetimi',             url: '/Warehouse' },
            { icon: 'fa-chart-line',       label: 'Satış Analitiği',   sub: 'Satış raporu',              url: '/Report/Sales' },
            { icon: 'fa-coins',            label: 'Stok Değeri',       sub: 'Stok değer raporu',         url: '/Report/StockValue' },
            { icon: 'fa-file-excel',       label: 'Excel İndir',       sub: 'Ürün Excel raporu',         url: '/Product/ExportExcel' },
            { icon: 'fa-shield-halved',    label: 'Denetim Günlüğü',   sub: 'Audit log',                 url: '/Audit' },
            { icon: 'fa-gear',             label: 'Sistem Ayarları',   sub: 'Ayarlar sayfası',           url: '/Settings' },
        ];

        let selectedIdx = 0;

        function openPalette() {
            const overlay = document.getElementById('cmdPaletteOverlay');
            overlay.style.display = 'flex';
            document.getElementById('cmdInput').value = '';
            filterCommands('');
            setTimeout(() => document.getElementById('cmdInput').focus(), 50);
        }

        function closePalette(e) {
            if (!e || e.target === document.getElementById('cmdPaletteOverlay') || e.key === 'Escape') {
                document.getElementById('cmdPaletteOverlay').style.display = 'none';
            }
        }

        function filterCommands(q) {
            const list = document.getElementById('cmdList');
            const filtered = COMMANDS.filter(c =>
                c.label.toLowerCase().includes(q.toLowerCase()) ||
                c.sub.toLowerCase().includes(q.toLowerCase()));

            list.innerHTML = filtered.map((c, i) => `
                <li onclick="window.location='${c.url}'" onmouseover="setSelected(${i})"
                    id="cmd-${i}"
                    style="display:flex;align-items:center;gap:14px;padding:12px 20px;cursor:pointer;transition:background .15s;
                           ${ i === 0 ? 'background:rgba(99,102,241,0.08);' : '' }">
                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(99,102,241,0.1);
                                display:flex;align-items:center;justify-content:center;color:var(--accent);font-size:15px;flex-shrink:0">
                        <i class="fa-solid ${c.icon}"></i>
                    </div>
                    <div>
                        <div style="font-size:14px;font-weight:600;color:var(--text-primary)">${c.label}</div>
                        <div style="font-size:12px;color:var(--text-muted)">${c.sub}</div>
                    </div>
                    <div style="margin-left:auto;font-size:11px;color:var(--text-muted)"><i class="fa-solid fa-arrow-right"></i></div>
                </li>`).join('');
            selectedIdx = 0;
        }

        function setSelected(i) { selectedIdx = i; }

        function handleKey(e) {
            const items = document.querySelectorAll('#cmdList li');
            if (e.key === 'ArrowDown') { selectedIdx = Math.min(selectedIdx + 1, items.length - 1); }
            else if (e.key === 'ArrowUp') { selectedIdx = Math.max(selectedIdx - 1, 0); }
            else if (e.key === 'Enter' && items[selectedIdx]) { items[selectedIdx].click(); return; }
            else if (e.key === 'Escape') { closePalette(e); return; }
            items.forEach((el, i) => el.style.background = i === selectedIdx ? 'rgba(99,102,241,0.08)' : '');
        }

        document.addEventListener('keydown', e => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openPalette(); }
            if (e.key === 'Escape') closePalette(e);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

