<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NovaStock ERP – Kurumsal Stok ve Bayi Yönetim Sistemi" />
    <title>@ViewData["Title"] – NovaStock ERP</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- NovaStock Premium Dark UI -->
        <style>
        :root {
            --bg-primary:    #f4f7fb;
            --bg-secondary:  #ffffff;
            --bg-card:       rgba(255,255,255,0.9);
            --bg-card-hover: rgba(255,255,255,1);
            --border-glass:  rgba(0,0,0,0.08);
            --accent:        #6366f1;
            --accent-light:  #4f46e5;
            --accent-glow:   rgba(99,102,241,0.25);
            --cyan:          #0ea5e9;
            --green:         #10b981;
            --red:           #ef4444;
            --yellow:        #f59e0b;
            --gold:          #f59e0b;
            --silver:        #64748b;
            --bronze:        #b45309;
            --text-primary:  #1e293b;
            --text-secondary:#334155;
            --text-muted:    #64748b;
            --sidebar-w:     260px;
            --navbar-h:      64px;
            --radius:        14px;
            --transition:    0.25s cubic-bezier(.4,0,.2,1);
        }

        /* �� Reset & Base ��������������������������������������������������� */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html, body { height: 100%; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
        }

        /* �� Scrollbar ������������������������������������������������������ */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-primary); }
        ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 3px; }

        /* �� Sidebar ������������������������������������������������������� */
        .sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--sidebar-w); height: 100vh;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border-glass);
            display: flex; flex-direction: column;
            z-index: 1000;
            transition: transform var(--transition);
        }

        .sidebar-brand {
            display: flex; align-items: center; gap: 12px;
            padding: 20px 22px;
            border-bottom: 1px solid var(--border-glass);
            text-decoration: none;
        }
        .sidebar-brand .brand-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--accent), #4f46e5);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; color: #fff;
            box-shadow: 0 0 20px var(--accent-glow);
        }
        .sidebar-brand .brand-name {
            font-size: 18px; font-weight: 700;
            background: linear-gradient(90deg, var(--accent-light), var(--cyan));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .sidebar-brand .brand-sub {
            font-size: 10px; color: var(--text-muted);
            font-weight: 400;
            -webkit-text-fill-color: var(--text-muted);
        }

        .sidebar-nav { flex: 1; padding: 16px 0; overflow-y: auto; }

        .nav-section-label {
            font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
            color: var(--text-muted); text-transform: uppercase;
            padding: 12px 22px 4px;
        }

        .nav-item-link {
            display: flex; align-items: center; gap: 12px;
            padding: 11px 22px;
            color: var(--text-secondary);
            text-decoration: none;
            border-radius: 0;
            font-size: 14px; font-weight: 500;
            transition: all var(--transition);
            position: relative;
        }
        .nav-item-link i { width: 20px; text-align: center; font-size: 15px; }
        .nav-item-link:hover, .nav-item-link.active {
            color: var(--accent);
            background: rgba(99,102,241,0.08);
        }
        .nav-item-link.active::before {
            content: '';
            position: absolute; left: 0; top: 50%;
            transform: translateY(-50%);
            width: 3px; height: 60%;
            background: var(--accent);
            border-radius: 0 3px 3px 0;
        }
        .nav-item-link.active i { color: var(--accent); }
        .nav-item-link .nav-badge {
            margin-left: auto;
            background: var(--red);
            color: #fff;
            font-size: 11px; font-weight: 600;
            padding: 2px 7px;
            border-radius: 10px;
            min-width: 22px; text-align: center;
        }

        .sidebar-footer {
            padding: 16px 22px;
            border-top: 1px solid var(--border-glass);
        }
        .sidebar-user {
            display: flex; align-items: center; gap: 10px;
        }
        .sidebar-user .user-avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--cyan));
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 700; color: #fff;
        }
        .sidebar-user .user-name { font-size: 13px; font-weight: 600; }
        .sidebar-user .user-role { font-size: 11px; color: var(--text-muted); }

        /* �� Top Navbar ���������������������������������������������������� */
        .top-navbar {
            position: fixed; top: 0;
            left: var(--sidebar-w); right: 0;
            height: var(--navbar-h);
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-glass);
            display: flex; align-items: center;
            padding: 0 28px; gap: 16px;
            z-index: 999;
        }
        .navbar-page-title {
            font-size: 16px; font-weight: 600;
            color: var(--text-primary); flex: 1;
        }
        .navbar-page-title span { color: var(--text-muted); font-weight: 400; font-size: 14px; }

        .navbar-action-btn {
            position: relative;
            width: 38px; height: 38px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-glass);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all var(--transition);
            text-decoration: none;
        }
        .navbar-action-btn:hover { color: var(--accent); border-color: var(--accent); }
        .navbar-action-btn .notif-dot {
            position: absolute; top: 6px; right: 6px;
            width: 8px; height: 8px;
            background: var(--red); border-radius: 50%;
            border: 2px solid var(--bg-secondary);
        }

        /* �� Main Content �������������������������������������������������� */
        .main-content {
            margin-left: var(--sidebar-w);
            margin-top: var(--navbar-h);
            padding: 28px;
            min-height: calc(100vh - var(--navbar-h));
        }

        /* �� Glass Card ���������������������������������������������������� */
        .glass-card {
            background: var(--bg-card);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius);
            backdrop-filter: blur(10px);
            transition: all var(--transition);
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        }
        .glass-card:hover { border-color: rgba(99,102,241,0.3); box-shadow: 0 4px 20px rgba(0,0,0,0.06); }

        /* �� Stat Cards ���������������������������������������������������� */
        .stat-card {
            display: block;
            text-decoration: none;
            background: var(--bg-card);
            border: 1px solid var(--border-glass);
            border-radius: var(--radius);
            padding: 22px;
            transition: all var(--transition);
            position: relative; overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        }
        .stat-card::before {
            content: ''; position: absolute;
            top: 0; left: 0; right: 0; height: 2px;
        }
        .stat-card.purple::before  { background: linear-gradient(90deg, var(--accent), #4f46e5); }
        .stat-card.cyan::before    { background: linear-gradient(90deg, var(--cyan), #0891b2); }
        .stat-card.green::before   { background: linear-gradient(90deg, var(--green), #059669); }
        .stat-card.red::before     { background: linear-gradient(90deg, var(--red), #dc2626); }
        .stat-card.yellow::before  { background: linear-gradient(90deg, var(--yellow), #d97706); }
        .stat-card:hover { transform: translateY(-2px); border-color: rgba(0,0,0,0.12); box-shadow: 0 8px 25px rgba(0,0,0,0.08); }

        .stat-icon {
            width: 46px; height: 46px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px; margin-bottom: 14px;
        }
        .stat-icon.purple { background: rgba(99,102,241,0.15); color: var(--accent); }
        .stat-icon.cyan   { background: rgba(14,165,233,0.15);  color: var(--cyan); }
        .stat-icon.green  { background: rgba(16,185,129,0.15); color: var(--green); }
        .stat-icon.red    { background: rgba(239,68,68,0.15);  color: var(--red); }
        .stat-icon.yellow { background: rgba(245,158,11,0.15); color: var(--yellow); }

        .stat-value { font-size: 28px; font-weight: 800; line-height: 1; margin-bottom: 4px; color: var(--text-primary); }
        .stat-label { font-size: 13px; color: var(--text-muted); font-weight: 500; }

        /* �� Buttons ������������������������������������������������������� */
        .btn-nova {
            background: linear-gradient(135deg, var(--accent), #4f46e5);
            color: #fff; border: none;
            padding: 9px 20px; border-radius: 10px;
            font-size: 13px; font-weight: 600;
            display: inline-flex; align-items: center; gap: 7px;
            transition: all var(--transition); cursor: pointer;
            text-decoration: none;
        }
        .btn-nova:hover { transform: translateY(-1px); box-shadow: 0 8px 25px var(--accent-glow); color: #fff; }

        .btn-nova-outline {
            background: transparent;
            border: 1px solid var(--accent);
            color: var(--accent);
            padding: 9px 20px; border-radius: 10px;
            font-size: 13px; font-weight: 600;
            display: inline-flex; align-items: center; gap: 7px;
            transition: all var(--transition); cursor: pointer;
            text-decoration: none;
        }
        .btn-nova-outline:hover { background: rgba(99,102,241,0.1); color: var(--accent); }

        .btn-danger-nova {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.3);
            color: var(--red);
            padding: 7px 14px; border-radius: 8px;
            font-size: 12px; font-weight: 600;
            transition: all var(--transition); cursor: pointer;
        }
        .btn-danger-nova:hover { background: rgba(239,68,68,0.2); color: var(--red); }

        /* �� Tables �������������������������������������������������������� */
        .nova-table { width: 100%; border-collapse: collapse; }
        .nova-table thead th {
            background: rgba(99,102,241,0.05);
            color: var(--text-muted); font-size: 11px;
            font-weight: 600; text-transform: uppercase;
            letter-spacing: 0.8px;
            padding: 12px 16px;
            border-bottom: 1px solid var(--border-glass);
        }
        .nova-table tbody tr { border-bottom: 1px solid rgba(0,0,0,0.04); transition: background var(--transition); }
        .nova-table tbody tr:hover { background: var(--bg-card-hover); }
        .nova-table tbody td { padding: 13px 16px; font-size: 13px; vertical-align: middle; }

        /* �� Badges �������������������������������������������������������� */
        .badge-nova { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge-purple { background: rgba(99,102,241,0.15); color: var(--accent); border: 1px solid rgba(99,102,241,0.25); }
        .badge-green  { background: rgba(16,185,129,0.15); color: var(--green); border: 1px solid rgba(16,185,129,0.25); }
        .badge-red    { background: rgba(239,68,68,0.15);  color: var(--red);  border: 1px solid rgba(239,68,68,0.25); }
        .badge-yellow { background: rgba(245,158,11,0.15); color: var(--yellow); border: 1px solid rgba(245,158,11,0.25); }
        .badge-cyan   { background: rgba(14,165,233,0.15);  color: var(--cyan); border: 1px solid rgba(14,165,233,0.25); }
        .badge-gray   { background: rgba(100,116,139,0.15); color: var(--text-muted); border: 1px solid rgba(100,116,139,0.2); }
        .badge-gold   { background: rgba(245,158,11,0.15); color: var(--gold); border: 1px solid rgba(245,158,11,0.25); }
        .badge-silver { background: rgba(100,116,139,0.1); color: var(--silver); border: 1px solid rgba(100,116,139,0.2); }
        .badge-bronze { background: rgba(180,83,9,0.15); color: var(--bronze); border: 1px solid rgba(180,83,9,0.25); }

        /* �� Critical Stock Alert ������������������������������������������ */
        .critical-row { background: rgba(239,68,68,0.06) !important; }
        .critical-badge {
            display: inline-flex; align-items: center; gap: 4px;
            animation: pulse-red 2s infinite;
        }
        @@keyframes pulse-red {
            0%,100% { opacity: 1; }
            50%      { opacity: 0.6; }
        }

        /* �� Form Controls ������������������������������������������������� */
        .form-nova {
            background: #ffffff;
            border: 1px solid rgba(0,0,0,0.15);
            border-radius: 10px;
            color: var(--text-primary);
            padding: 10px 14px;
            font-size: 14px;
            width: 100%;
            transition: border-color var(--transition);
        }
        .form-nova:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px var(--accent-glow);
            background: #ffffff;
            color: var(--text-primary);
        }
        .form-nova option { background: #ffffff; color: var(--text-primary); }
        .form-label-nova { font-size: 13px; font-weight: 500; color: var(--text-secondary); margin-bottom: 6px; display: block; }

        /* �� Alerts �������������������������������������������������������� */
        .alert-nova {
            border-radius: 10px; padding: 12px 16px;
            font-size: 13px; font-weight: 500;
            display: flex; align-items: center; gap: 10px;
            border: 1px solid;
        }
        .alert-success-nova { background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.3); color: var(--green); }
        .alert-danger-nova  { background: rgba(239,68,68,0.1);  border-color: rgba(239,68,68,0.3);  color: var(--red); }
        .alert-warning-nova { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.3); color: var(--yellow); }

        /* �� Page Header ��������������������������������������������������� */
        .page-header {
            display: flex; align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }
        .page-header h1 { font-size: 22px; font-weight: 700; }
        .page-header .breadcrumb-nova { font-size: 13px; color: var(--text-muted); margin-top: 2px; }

        /* �� SignalR Toast Notification ������������������������������������ */
        #toast-container {
            position: fixed; top: 80px; right: 20px;
            z-index: 9999; display: flex; flex-direction: column; gap: 10px;
        }
        .nova-toast {
            background: var(--bg-secondary);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            padding: 14px 18px;
            min-width: 300px; max-width: 380px;
            display: flex; align-items: flex-start; gap: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            animation: slideInRight 0.4s ease;
        }
        @@keyframes slideInRight {
            from { opacity: 0; transform: translateX(100%); }
            to   { opacity: 1; transform: translateX(0); }
        }
        .nova-toast.order   { border-left: 3px solid var(--green); }
        .nova-toast.stock   { border-left: 3px solid var(--red); }
        .nova-toast.support { border-left: 3px solid var(--accent); }
        .nova-toast .toast-icon { font-size: 20px; flex-shrink: 0; }
        .nova-toast.order .toast-icon   { color: var(--green); }
        .nova-toast.stock .toast-icon   { color: var(--red); }
        .nova-toast.support .toast-icon { color: var(--accent); }
        .nova-toast .toast-body .toast-title { font-size: 13px; font-weight: 700; margin-bottom: 3px; }
        .nova-toast .toast-body .toast-msg   { font-size: 12px; color: var(--text-muted); }
        .nova-toast .toast-time { font-size: 11px; color: var(--text-muted); margin-left: auto; flex-shrink: 0; }

        /*  Notification Dropdown  */
        .notif-dropdown {
            position: absolute; top: 60px; right: 28px;
            width: 340px; background: var(--bg-secondary);
            border: 1px solid var(--border-glass); border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            display: none; flex-direction: column; z-index: 1000;
            overflow: hidden;
        }
        .notif-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 14px 18px; border-bottom: 1px solid var(--border-glass);
            font-weight: 600; font-size: 14px; background: rgba(99,102,241,0.02);
        }
        .notif-header button {
            background: none; border: none; color: var(--accent);
            font-size: 12px; font-weight: 500; cursor: pointer; transition: color var(--transition);
        }
        .notif-header button:hover { color: var(--accent-light); }
        .notif-body {
            max-height: 380px; overflow-y: auto;
        }
        .notif-item {
            display: flex; gap: 14px; padding: 14px 18px;
            border-bottom: 1px solid var(--border-glass);
            cursor: pointer; transition: background 0.2s;
        }
        .notif-item:hover { background: rgba(0,0,0,0.02); }
        .notif-item.unread { background: rgba(99,102,241,0.05); }
        .notif-item-icon {
            width: 38px; height: 38px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; flex-shrink: 0;
        }
        .notif-item.order .notif-item-icon { background: rgba(16,185,129,0.15); color: var(--green); }
        .notif-item.stock .notif-item-icon { background: rgba(239,68,68,0.15); color: var(--red); }
        .notif-item-content { flex: 1; }
        .notif-item-title { font-size: 13px; font-weight: 700; margin-bottom: 3px; color: var(--text-primary); }
        .notif-item-msg { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
        .notif-item-time { font-size: 11px; color: var(--text-muted); margin-top: 6px; }

        /*  Responsive  */
        @@media (max-width: 992px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.open { transform: translateX(0); }
            .main-content, .top-navbar { left: 0; margin-left: 0; }
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
    <nav class="sidebar" id="sidebar">
        <a href="/" class="sidebar-brand">
            <div class="brand-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div>
                <div class="brand-name">NovaStock</div>
                <div class="brand-sub">Enterprise ERP v1.0</div>
            </div>
        </a>

        <div class="sidebar-nav">

            @if (User.IsInRole("Admin"))
            {
                @* ── ADMİN MENÜSÜ ──────────────────────────────────────────────────── *@
                <div class="nav-section-label">Ana Menü</div>
                <a href="/" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i> Dashboard
                </a>
                <a href="/Product" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                    <i class="fa-solid fa-box-open"></i> Ürünler
                </a>
                <a href="/Order" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                    <i class="fa-solid fa-cart-shopping"></i> Siparişler
                    @if (ViewBag.PendingCount != null && (int)ViewBag.PendingCount > 0)
                    {
                        <span class="nav-badge">@ViewBag.PendingCount</span>
                    }
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Yönetim</div>
                <a href="/Dealer" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dealer" ? "active" : "")">
                    <i class="fa-solid fa-users"></i> Bayiler
                </a>
                <a href="/Supplier" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Supplier" ? "active" : "")">
                    <i class="fa-solid fa-truck-ramp-box"></i> Tedarikçiler
                </a>
                <a href="/Promotion" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Promotion" ? "active" : "")">
                    <i class="fa-solid fa-tag"></i> Kampanyalar
                </a>
                <a href="/Warehouse" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Warehouse" ? "active" : "")">
                    <i class="fa-solid fa-warehouse"></i> Depolar
                </a>
                <a href="/Audit" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audit" ? "active" : "")">
                    <i class="fa-solid fa-shield-halved"></i> Denetim Günlüğü
                </a>
                <a href="/Product/Recycle" class="nav-item-link">
                    <i class="fa-solid fa-trash-can-arrow-up"></i> Geri Dönüşüm
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Destek</div>
                <a href="/Support" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Support" ? "active" : "")">
                    <i class="fa-solid fa-headset"></i> Destek Talepleri
                    <span class="nav-badge" id="adminTicketBadge" style="display:none"></span>
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Raporlar</div>
                <a href="/Report/Sales" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Sales" ? "active" : "")">
                    <i class="fa-solid fa-chart-line"></i> Satış Analitiği
                </a>
                <a href="/Report/StockValue" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "StockValue" ? "active" : "")">
                    <i class="fa-solid fa-coins"></i> Stok Değeri
                </a>
                <a href="/Product/ExportExcel" class="nav-item-link">
                    <i class="fa-solid fa-file-excel"></i> Excel Raporu
                </a>
            }
            else
            {
                @* ── BAYİ MÜŞTERİ PORTALI MENÜSÜ ───────────────────────────────────── *@
                <div class="nav-section-label">Ana Menü</div>
                <a href="/" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i> Dashboard
                </a>
                <a href="/Product" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                    <i class="fa-solid fa-store"></i> Ürün Kataloğu
                </a>
                <a href="/Order" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                    <i class="fa-solid fa-clipboard-list"></i> Siparişlerim
                    @if (ViewBag.PendingCount != null && (int)ViewBag.PendingCount > 0)
                    {
                        <span class="nav-badge">@ViewBag.PendingCount</span>
                    }
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Finans ve Raporlar</div>
                <a href="/Dealer/Statement" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dealer" && ViewContext.RouteData.Values["action"]?.ToString() == "Statement" ? "active" : "")">
                    <i class="fa-solid fa-file-invoice-dollar"></i> Cari Hesap Ekstresi
                </a>
                <a href="/Product/ExportPriceList" class="nav-item-link">
                    <i class="fa-solid fa-tags"></i> Özel Fiyat Listesi (Excel)
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Toplu İşlemler</div>
                <a href="/Order?BulkMode=true" class="nav-item-link">
                    <i class="fa-solid fa-file-excel"></i> Toplu Excel Sipariş
                </a>
                <a href="/Order?Frequent=true" class="nav-item-link">
                    <i class="fa-solid fa-star"></i> Sık Satın Aldıklarım
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Destek & Ekip</div>
                <a href="/Support" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Support" ? "active" : "")">
                    <i class="fa-solid fa-headset"></i> Destek Talepleri
                    <span class="nav-badge" id="dealerTicketBadge" style="display:none"></span>
                </a>
                <a href="/Dealer/TeamManagement" class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "TeamManagement" ? "active" : "")">
                    <i class="fa-solid fa-users-gear"></i> Ekip Yönetimi
                </a>
            }

        </div>


        <!-- Sistem Ayarları -->
        @if (User.IsInRole("Admin"))
        {
            <div style="padding:8px 12px;border-top:1px solid var(--border-glass)">
                <a href="/Settings" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")" style="padding:10px;border-radius:10px">
                    <i class="fa-solid fa-gear"></i> Sistem Ayarları
                </a>
            </div>
        }
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="user-avatar">
                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "N")
                </div>
                <div>
                    <div class="user-name">@User.Identity?.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrator" : "Bayi")</div>
                </div>
                <form method="post" action="/Account/Logout" style="margin-left:auto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="navbar-action-btn" title="Çıkış">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <!-- ── Top Navbar ──────────────────────────────────────────────────────── -->
    <header class="top-navbar">
        <button class="navbar-action-btn d-lg-none" id="sidebarToggle">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="navbar-page-title">
            @ViewData["Title"] <span>/ NovaStock ERP</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
            <div id="realtime-indicator" style="display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-muted)">
                <span id="connection-dot" style="width:8px;height:8px;border-radius:50%;background:var(--text-muted);display:inline-block"></span>
                <span id="connection-label">Bağlanıyor...</span>
            </div>
            <a href="/Product/ExportExcel" class="navbar-action-btn" title="Excel İndir">
                <i class="fa-solid fa-file-excel"></i>
            </a>
            <div class="navbar-action-btn" id="notifBtn" title="Bildirimler" onclick="toggleNotifDropdown()">
                <i class="fa-solid fa-bell"></i>
                <span class="notif-dot" id="notifDot" style="display:none; text-align:center; color:#fff; font-size:8px; line-height:10px; font-weight:bold; width:12px; height:12px; top:4px; right:4px;"></span>
            </div>
        </div>

        <!-- Notification Dropdown -->
        <div id="notifDropdown" class="notif-dropdown">
            <div class="notif-header">
                <span>Bildirimler</span>
                <button onclick="markAllAsRead(event)"><i class="fa-solid fa-check-double"></i> Tümünü Okundu İşaretle</button>
            </div>
            <div class="notif-body" id="notifList">
                <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px">Yükleniyor...</div>
            </div>
        </div>
    </header>

    <!-- ── SignalR Toast Container ─────────────────────────────────────────── -->
    <div id="toast-container"></div>

    <!-- ── Alert Messages ─────────────────────────────────────────────────── -->
    <div class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert-nova alert-success-nova mb-4" id="tempAlert">
                <i class="fa-solid fa-circle-check"></i>
                @TempData["Success"]
                <button onclick="this.parentElement.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer">×</button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-nova alert-danger-nova mb-4" id="tempAlert">
                <i class="fa-solid fa-triangle-exclamation"></i>
                @TempData["Error"]
                <button onclick="this.parentElement.remove()" style="margin-left:auto;background:none;border:none;color:inherit;cursor:pointer">×</button>
            </div>
        }

        @RenderBody()
    </div>

    <!-- ── Scripts ─────────────────────────────────────────────────────────── -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <!-- ── Komut Paleti (Ctrl+K) ─────────────────────────────────────────────── -->
    <div id="cmdPaletteOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;display:none;align-items:flex-start;justify-content:center;padding-top:80px" onclick="closePalette(event)">
        <div id="cmdPalette" style="background:#fff;border-radius:16px;width:100%;max-width:560px;box-shadow:0 20px 60px rgba(0,0,0,0.25);overflow:hidden">
            <div style="display:flex;align-items:center;gap:12px;padding:16px 20px;border-bottom:1px solid var(--border-glass)">
                <i class="fa-solid fa-magnifying-glass" style="color:var(--text-muted)"></i>
                <input id="cmdInput" type="text" placeholder="Bir sayfa veya komut arayın..." autocomplete="off"
                       style="flex:1;border:none;outline:none;font-size:15px;font-family:inherit;color:var(--text-primary);background:transparent"
                       oninput="filterCommands(this.value)" onkeydown="handleKey(event)">
                <kbd style="font-size:11px;background:var(--border-glass);padding:3px 7px;border-radius:6px;color:var(--text-muted)">ESC</kbd>
            </div>
            <ul id="cmdList" style="list-style:none;padding:8px 0;max-height:360px;overflow-y:auto;margin:0"></ul>
        </div>
    </div>

    <script>
        // ── Sidebar Toggle (Mobile) ─────────────────────────────────────────
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('sidebar').classList.toggle('open');
        });

        // ── Auto-dismiss alerts ─────────────────────────────────────────────
        setTimeout(() => {
            document.getElementById('tempAlert')?.remove();
        }, 5000);

        // ── Toast Factory ───────────────────────────────────────────────────
        function showToast(type, icon, title, message, time) {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `nova-toast ${type}`;
            toast.innerHTML = `
                <div class="toast-icon"><i class="${icon}"></i></div>
                <div class="toast-body">
                    <div class="toast-title">${title}</div>
                    <div class="toast-msg">${message}</div>
                </div>
                <div class="toast-time">${time}</div>`;
            container.appendChild(toast);
            // Ses efekti (basit beep)
            try {
                const ctx = new AudioContext();
                const osc = ctx.createOscillator();
                const gain = ctx.createGain();
                osc.connect(gain); gain.connect(ctx.destination);
                osc.frequency.value = type === 'order' ? 880 : 440;
                gain.gain.setValueAtTime(0.1, ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.4);
                osc.start(); osc.stop(ctx.currentTime + 0.4);
            } catch(e) {}
            setTimeout(() => toast.remove(), 6000);
        }

        // ── Notifications (UI & SignalR) ────────────────────────────────────
        let unreadCount = 0;

        async function fetchNotifications() {
            try {
                const res = await fetch('/Notification/GetLatest');
                const data = await res.json();
                if(data.success) {
                    unreadCount = data.unreadCount;
                    updateNotifDot();
                    renderNotifications(data.notifications);
                }
            } catch (e) { console.error(e); }
        }

        function updateNotifDot() {
            const dot = document.getElementById('notifDot');
            if(unreadCount > 0) {
                dot.style.display = 'block';
                dot.textContent = unreadCount > 9 ? '9+' : unreadCount;
            } else {
                dot.style.display = 'none';
            }
        }

        function renderNotifications(list) {
            const container = document.getElementById('notifList');
            if(list.length === 0) {
                container.innerHTML = '<div style="padding:30px 20px;text-align:center;color:var(--text-muted);font-size:13px"><i class="fa-regular fa-bell-slash" style="font-size:24px;margin-bottom:10px;opacity:0.5;display:block"></i>Yeni bildirim yok.</div>';
                return;
            }
            container.innerHTML = list.map(n => `
                <div class="notif-item ${n.type} ${n.isRead ? '' : 'unread'}" onclick="markAsRead(${n.id}, this)">
                    <div class="notif-item-icon"><i class="fa-solid ${n.iconClass || 'fa-bell'}"></i></div>
                    <div class="notif-item-content">
                        <div class="notif-item-title">${n.title}</div>
                        <div class="notif-item-msg">${n.message}</div>
                        <div class="notif-item-time">${n.timeAgo}</div>
                    </div>
                </div>
            `).join('');
        }

        function toggleNotifDropdown() {
            const dropdown = document.getElementById('notifDropdown');
            dropdown.style.display = dropdown.style.display === 'flex' ? 'none' : 'flex';
        }

        async function markAsRead(id, el) {
            if(!el.classList.contains('unread')) return;
            try {
                await fetch('/Notification/MarkAsRead?id=' + id, { method: 'POST' });
                el.classList.remove('unread');
                unreadCount = Math.max(0, unreadCount - 1);
                updateNotifDot();
            } catch (e) {}
        }

        async function markAllAsRead(e) {
            if (e) e.stopPropagation();
            try {
                await fetch('/Notification/MarkAllAsRead', { method: 'POST' });
                unreadCount = 0;
                updateNotifDot();
                document.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
            } catch (e) {}
        }

        document.addEventListener('click', (e) => {
            const btn = document.getElementById('notifBtn');
            const dropdown = document.getElementById('notifDropdown');
            if(btn && dropdown && !btn.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.style.display = 'none';
            }
        });

        // ── Ticket rozeti güncelleme ──────────────────────────────────────────
        async function fetchTicketCounts() {
            try {
                const res  = await fetch('/Notification/GetCounts');
                const data = await res.json();
                const badge = document.getElementById('adminTicketBadge');
                if (badge) {
                    if (data.openTicketCount > 0) {
                        badge.textContent = data.openTicketCount > 9 ? '9+' : data.openTicketCount;
                        badge.style.display = 'inline-flex';
                    } else {
                        badge.style.display = 'none';
                    }
                }
                // Bayi: yanıtlanan talep rozeti (sidebar'da varsa)
                const dealerBadge = document.getElementById('dealerTicketBadge');
                if (dealerBadge) {
                    if (data.openTicketCount > 0) {
                        dealerBadge.textContent = data.openTicketCount > 9 ? '9+' : data.openTicketCount;
                        dealerBadge.style.display = 'inline-flex';
                    } else {
                        dealerBadge.style.display = 'none';
                    }
                }
            } catch (e) { console.error(e); }
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetchNotifications();
            fetchTicketCounts();
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveOrderNotification", data => {
            fetchNotifications(); // UI'ı yenile
            showToast('order', 'fa-solid fa-cart-check',
                'Yeni Sipariş!',
                `${data.dealerName} – ${data.total} ₺`,
                data.timestamp);
        });

        connection.on("ReceiveStockAlert", data => {
            fetchNotifications(); // UI'ı yenile
            showToast('stock', 'fa-solid fa-triangle-exclamation',
                '⚠️ Kritik Stok!',
                `${data.productName}: ${data.remainingStock} adet kaldı`,
                data.timestamp);
        });

        // ── Destek Talebi Bildirimi (Admin tarafı) ───────────────────────────
        connection.on("ReceiveSupportTicketNotification", data => {
            fetchNotifications();
            fetchTicketCounts();
            showToast('support', 'fa-solid fa-headset',
                'Yeni Destek Talebi',
                `${data.dealerName}: ${data.subject}`,
                data.timestamp);
        });

        // ── Bayi Bildirimi (Bayi tarafı) ─────────────────────────────────────
        connection.on("ReceiveDealerNotification", data => {
            fetchNotifications();
            fetchTicketCounts();
            showToast('support', 'fa-solid fa-headset',
                'Destek Talebiniz Güncellendi',
                data.message,
                data.timestamp);
        });

        async function startSignalR() {
            const dot   = document.getElementById('connection-dot');
            const label = document.getElementById('connection-label');
            try {
                await connection.start();
                dot.style.background   = 'var(--green)';
                label.textContent      = 'Canlı';
                label.style.color      = 'var(--green)';
            } catch (err) {
                dot.style.background   = 'var(--red)';
                label.textContent      = 'Bağlantı yok';
            }
        }
        startSignalR();

        // ── Komut Paleti (Ctrl+K) ──────────────────────────────────────────────
        const COMMANDS = [
            { icon: 'fa-gauge-high',       label: 'Dashboard',         sub: 'Ana sayfa',                 url: '/' },
            { icon: 'fa-box-open',         label: 'Ürünler',           sub: 'Ürün yönetimi',             url: '/Product' },
            { icon: 'fa-plus',             label: 'Yeni Ürün Ekle',    sub: 'Ürün oluştur',              url: '/Product/Create' },
            { icon: 'fa-cart-shopping',    label: 'Siparişler',        sub: 'Sipariş yönetimi',          url: '/Order' },
            { icon: 'fa-users',            label: 'Bayiler',           sub: 'Bayi listesi',              url: '/Dealer' },
            { icon: 'fa-truck-ramp-box',   label: 'Tedarikçiler',      sub: 'Tedarikçi yönetimi',        url: '/Supplier' },
            { icon: 'fa-boxes-stacked',    label: 'Mal Kabul',         sub: 'Stok artır',                url: '/Supplier/Purchase' },
            { icon: 'fa-tag',              label: 'Kampanyalar',       sub: 'Fiyat politikası',          url: '/Promotion' },
            { icon: 'fa-warehouse',        label: 'Depolar',           sub: 'Depo yönetimi',             url: '/Warehouse' },
            { icon: 'fa-chart-line',       label: 'Satış Analitiği',   sub: 'Satış raporu',              url: '/Report/Sales' },
            { icon: 'fa-coins',            label: 'Stok Değeri',       sub: 'Stok değer raporu',         url: '/Report/StockValue' },
            { icon: 'fa-file-excel',       label: 'Excel İndir',       sub: 'Ürün Excel raporu',         url: '/Product/ExportExcel' },
            { icon: 'fa-shield-halved',    label: 'Denetim Günlüğü',   sub: 'Audit log',                 url: '/Audit' },
            { icon: 'fa-gear',             label: 'Sistem Ayarları',   sub: 'Ayarlar sayfası',           url: '/Settings' },
        ];

        let selectedIdx = 0;

        function openPalette() {
            const overlay = document.getElementById('cmdPaletteOverlay');
            overlay.style.display = 'flex';
            document.getElementById('cmdInput').value = '';
            filterCommands('');
            setTimeout(() => document.getElementById('cmdInput').focus(), 50);
        }

        function closePalette(e) {
            if (!e || e.target === document.getElementById('cmdPaletteOverlay') || e.key === 'Escape') {
                document.getElementById('cmdPaletteOverlay').style.display = 'none';
            }
        }

        function filterCommands(q) {
            const list = document.getElementById('cmdList');
            const filtered = COMMANDS.filter(c =>
                c.label.toLowerCase().includes(q.toLowerCase()) ||
                c.sub.toLowerCase().includes(q.toLowerCase()));

            list.innerHTML = filtered.map((c, i) => `
                <li onclick="window.location='${c.url}'" onmouseover="setSelected(${i})"
                    id="cmd-${i}"
                    style="display:flex;align-items:center;gap:14px;padding:12px 20px;cursor:pointer;transition:background .15s;
                           ${ i === 0 ? 'background:rgba(99,102,241,0.08);' : '' }">
                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(99,102,241,0.1);
                                display:flex;align-items:center;justify-content:center;color:var(--accent);font-size:15px;flex-shrink:0">
                        <i class="fa-solid ${c.icon}"></i>
                    </div>
                    <div>
                        <div style="font-size:14px;font-weight:600;color:var(--text-primary)">${c.label}</div>
                        <div style="font-size:12px;color:var(--text-muted)">${c.sub}</div>
                    </div>
                    <div style="margin-left:auto;font-size:11px;color:var(--text-muted)"><i class="fa-solid fa-arrow-right"></i></div>
                </li>`).join('');
            selectedIdx = 0;
        }

        function setSelected(i) { selectedIdx = i; }

        function handleKey(e) {
            const items = document.querySelectorAll('#cmdList li');
            if (e.key === 'ArrowDown') { selectedIdx = Math.min(selectedIdx + 1, items.length - 1); }
            else if (e.key === 'ArrowUp') { selectedIdx = Math.max(selectedIdx - 1, 0); }
            else if (e.key === 'Enter' && items[selectedIdx]) { items[selectedIdx].click(); return; }
            else if (e.key === 'Escape') { closePalette(e); return; }
            items.forEach((el, i) => el.style.background = i === selectedIdx ? 'rgba(99,102,241,0.08)' : '');
        }

        document.addEventListener('keydown', e => {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); openPalette(); }
            if (e.key === 'Escape') closePalette(e);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

