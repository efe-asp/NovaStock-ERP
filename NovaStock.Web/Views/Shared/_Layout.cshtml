                <div class="nav-section-label" style="margin-top:10px;">Finans ve Raporlar</div>
                <a href="/Dealer/Statement" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dealer" && ViewContext.RouteData.Values["action"]?.ToString() == "Statement" ? "active" : "")">
                    <i class="fa-solid fa-file-invoice-dollar"></i> Cari Hesap Ekstresi
                </a>
                <a href="/Product/ExportPriceList" class="nav-item-link">
                    <i class="fa-solid fa-tags"></i> Özel Fiyat Listesi (Excel)
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Toplu İşlemler</div>
                <a href="/Order?BulkMode=true" class="nav-item-link">
                    <i class="fa-solid fa-file-excel"></i> Toplu Excel Sipariş
                </a>
                <a href="/Order?Frequent=true" class="nav-item-link">
                    <i class="fa-solid fa-star"></i> Sık Satın Aldıklarım
                </a>

                <div class="nav-section-label" style="margin-top:10px;">Destek & Ekip</div>
                <a href="/Support" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Support" ? "active" : "")">
                    <i class="fa-solid fa-headset"></i> Destek Talepleri
                    <span class="nav-badge" id="dealerTicketBadge" style="display:none"></span>
                </a>
                <a href="/Dealer/TeamManagement" class="nav-item-link @(ViewContext.RouteData.Values["action"]?.ToString() == "TeamManagement" ? "active" : "")">
                    <i class="fa-solid fa-users-gear"></i> Ekip Yönetimi
                </a>
            }

        </div>


        <!-- Sistem Ayarları -->
        @if (User.IsInRole("Admin"))
        {
            <div style="padding:8px 12px;border-top:1px solid var(--border-glass)">
                <a href="/Settings" class="nav-item-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")" style="padding:10px;border-radius:10px">
                    <i class="fa-solid fa-gear"></i> Sistem Ayarları
                </a>
            </div>
        }
        <div class="sidebar-footer">
            <div class="sidebar-user" id="profileTrigger" onclick="toggleProfilePanel()" title="Profil & Ayarlar">
                <div class="user-avatar" id="sidebarAvatar">
                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "N")
                </div>
                <div style="flex:1;min-width:0">
                    <div class="user-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@User.Identity?.Name</div>
                    <div class="user-role">@(User.IsInRole("Admin") ? "Administrator" : User.IsInRole("DealerFinance") ? "Muhasebe Personeli" : User.IsInRole("DealerPurchase") ? "Satın Alma Personeli" : "Bayi")</div>
                </div>
                <i class="fa-solid fa-ellipsis-vertical" style="color:var(--text-muted);font-size:14px;margin-left:4px"></i>
            </div>
        </div>
    </nav>

    <!-- ── Profil Paneli ─────────────────────────────────────────────────────── -->
    <div id="profilePanel">
        <!-- Header -->
        <div class="prof-header">
            <div style="display:flex;align-items:center;gap:12px">
                <div id="panelAvatar" style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#fff;flex-shrink:0"></div>
                <div style="min-width:0">
                    <div id="panelName" style="font-weight:700;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></div>
                    <div id="panelEmail" style="font-size:11px;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis"></div>
                    <div id="panelRoleBadge" style="margin-top:4px"></div>
                </div>
                <form method="post" action="/Account/Logout" style="margin-left:auto;flex-shrink:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="navbar-action-btn" title="Çıkış Yap" style="width:32px;height:32px;border-radius:8px">
                        <i class="fa-solid fa-right-from-bracket" style="font-size:13px"></i>
                    </button>
                </form>
            </div>
        </div>

        <!-- Sekmeler -->
        <div class="prof-tabs">
            <div class="prof-tab active" onclick="switchProfTab('profil')">👤 Profil</div>
            <div class="prof-tab" onclick="switchProfTab('guvenlik')">🔑 Güvenlik</div>
            <div class="prof-tab" onclick="switchProfTab('tema')">🎨 Tema</div>
            <div class="prof-tab" onclick="switchProfTab('hizli')">⚡ Hızlı</div>
        </div>

        <!-- Sekme: Profil -->
        <div id="tab-profil" class="prof-tab-content active">
            <div class="prof-field">
                <label>Ad Soyad</label>
                <input type="text" id="profFullName" placeholder="Ad Soyad" />
            </div>
            <div class="prof-field">
                <label>Telefon</label>
                <input type="tel" id="profPhone" placeholder="+90 5xx xxx xx xx" />
            </div>
            <div class="prof-field">
                <label>Adres</label>
                <input type="text" id="profAddress" placeholder="Adres bilgisi" />
            </div>
            <button class="prof-btn prof-btn-primary" onclick="saveProfile()"><i class="fa-solid fa-floppy-disk"></i> Kaydet</button>
            <div class="prof-msg" id="profMsg"></div>
        </div>

        <!-- Sekme: Güvenlik -->
        <div id="tab-guvenlik" class="prof-tab-content">
            <div class="prof-field">
                <label>Mevcut Şifre</label>
                <input type="password" id="pwCurrent" placeholder="••••••••" />
            </div>
            <div class="prof-field">
                <label>Yeni Şifre</label>
                <input type="password" id="pwNew" placeholder="En az 6 karakter" />
            </div>
            <div class="prof-field">
                <label>Yeni Şifre Tekrar</label>
                <input type="password" id="pwConfirm" placeholder="••••••••" />
            </div>
            <button class="prof-btn prof-btn-primary" onclick="changePassword()"><i class="fa-solid fa-lock"></i> Şifreyi Değiştir</button>
            <div class="prof-msg" id="pwMsg"></div>
        </div>

        <!-- Sekme: Tema -->
        <div id="tab-tema" class="prof-tab-content">
            <div class="theme-toggle-row">
                <span style="font-size:13px;font-weight:600">Mod</span>
                <div style="display:flex;gap:6px">
                    <button class="theme-toggle-btn" id="btnLight" onclick="applyTheme('light')"><i class="fa-solid fa-sun"></i> Açık</button>
                    <button class="theme-toggle-btn" id="btnDark" onclick="applyTheme('dark')"><i class="fa-solid fa-moon"></i> Koyu</button>
                </div>
            </div>
