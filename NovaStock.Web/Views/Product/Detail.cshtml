@model NovaStock.Web.ViewModels.ProductDetailViewModel
@using NovaStock.Web.Extensions
@using NovaStock.Web.Models
@{
    ViewData["Title"] = Model.Product.Name + " – Ürün Detayı";
    var p       = Model.Product;
    var specs   = Model.Specs;
    var isCrit  = p.StockCount <= p.CriticalStockLevel;
    var vatRate = p.VatRate;
    var costPrice  = p.CostPrice ?? 0;
    var bronzePrice = p.BasePrice;
    var silverPrice = Math.Round(p.BasePrice * 0.95m, 2);
    var goldPrice   = Math.Round(p.BasePrice * 0.90m, 2);
    var bronzeMargin = costPrice > 0 ? Math.Round((bronzePrice - costPrice) / costPrice * 100, 1) : 0;
    var silverMargin = costPrice > 0 ? Math.Round((silverPrice - costPrice) / costPrice * 100, 1) : 0;
    var goldMargin   = costPrice > 0 ? Math.Round((goldPrice   - costPrice) / costPrice * 100, 1) : 0;
    var allImages = new List<string>();
    if (!string.IsNullOrEmpty(p.ImageUrl)) allImages.Add(p.ImageUrl);
    allImages.AddRange(specs.ImageUrls.Where(u => !string.IsNullOrEmpty(u) && u != p.ImageUrl));
}

<style>
/* ─── Genel Sayfa ─────────────────────────────── */
.detail-grid          { display:grid; grid-template-columns: 1fr 420px; gap:20px; }
@@media(max-width:1100px){ .detail-grid { grid-template-columns:1fr; } }

/* ─── Galeri Carousel ─────────────────────────── */
.gallery-wrap         { position:relative; border-radius:18px; overflow:hidden;
                        background:rgba(0,0,0,0.3); aspect-ratio:4/3;
                        border:1px solid var(--border-glass); }
.gallery-img          { position:absolute; inset:0; width:100%; height:100%;
                        object-fit:contain; opacity:0;
                        transition:opacity .5s ease; padding:16px; }
.gallery-img.active   { opacity:1; }
.gallery-placeholder  { display:flex; flex-direction:column; align-items:center;
                        justify-content:center; height:100%;
                        color:var(--text-muted); font-size:14px; gap:12px; }
.gallery-dots         { display:flex; gap:6px; justify-content:center; margin-top:12px; }
.gallery-dot          { width:8px; height:8px; border-radius:50%;
                        background:rgba(255,255,255,.2); cursor:pointer;
                        transition:background .3s; border:none; }
.gallery-dot.active   { background:var(--accent); }
.gallery-nav          { position:absolute; top:50%; transform:translateY(-50%);
                        background:rgba(0,0,0,.5); border:none; color:#fff;
                        width:32px; height:32px; border-radius:50%; cursor:pointer;
                        display:flex; align-items:center; justify-content:center;
                        font-size:13px; transition:background .2s; }
.gallery-nav:hover    { background:rgba(0,0,0,.8); }
.gallery-nav.prev     { left:10px; }
.gallery-nav.next     { right:10px; }

/* ─── Etiketler ───────────────────────────────── */
.sku-badge            { font-family:monospace; font-size:13px; padding:4px 10px;
                        background:rgba(var(--accent-rgb),.15); border:1px solid rgba(var(--accent-rgb),.3);
                        border-radius:8px; color:var(--accent-light); display:inline-block; }
/* ─── Progress Bar ────────────────────────────── */
.stock-bar-wrap       { background:rgba(255,255,255,.06); border-radius:6px;
                        height:8px; overflow:hidden; margin-top:6px; }
.stock-bar-fill       { height:100%; border-radius:6px; transition:width .8s ease; }
/* ─── İç Kutu (Glassmorphism) ─────────────────── */
.inner-glass-box      { background:rgba(255,255,255,.04); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
                        border:1px solid rgba(255,255,255,.08); border-radius:10px; box-shadow:0 8px 32px rgba(0,0,0,.05); }

/* ─── Fiyat Matrisi ───────────────────────────── */
.price-tier-card      { border-radius:12px; padding:14px 16px;
                        border:1px solid var(--border-glass);
                        background:rgba(255,255,255,.04); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
                        box-shadow:0 8px 32px rgba(0,0,0,.05); }
/* ─── Teknik Özellikler Grid ──────────────────── */
.specs-kv-grid        { display:grid; grid-template-columns:auto 1fr; gap:0; }
.specs-kv-row         { display:contents; }
.specs-kv-row > *     { padding:8px 10px; border-bottom:1px solid rgba(255,255,255,.05);
                        font-size:13px; }
.specs-kv-row > *:first-child { color:var(--text-muted); font-weight:500; white-space:nowrap;
                                 padding-right:20px; }
.specs-kv-row > *:last-child  { color:var(--text-primary); }
.specs-kv-row:last-child > *  { border-bottom:none; }

/* ─── Sipariş tablosu ─────────────────────────── */
.recent-status-badge  { font-size:10px; padding:2px 8px; border-radius:100px; font-weight:600;
                        text-transform:uppercase; letter-spacing:.5px; }
</style>

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 style="font-size:22px">
            <i class="fa-solid fa-box-open" style="color:var(--accent-light);margin-right:10px"></i>
            @p.Name
        </h1>
        <div class="breadcrumb-nova">
            <a href="/Product" style="color:var(--accent-light);text-decoration:none">Ürünler</a>
            / @p.Name
        </div>
    </div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
        @if (User.IsInRole("Admin"))
        {
            <a href="/Product/Edit/@p.Id" class="btn-nova">
                <i class="fa-solid fa-pen"></i> Düzenle
            </a>
        }
        <a href="/Product" class="btn-nova-outline">
            <i class="fa-solid fa-arrow-left"></i> Geri
        </a>
    </div>
</div>

<div class="detail-grid">
    <!-- ══════════════════ SOL SÜTUN ══════════════════ -->
    <div style="display:flex;flex-direction:column;gap:20px">

        <!-- ① Kimlik & Galeri -->
        <div class="glass-card p-4">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
                <!-- Galeri -->
                <div>
                    <div class="gallery-wrap" id="gallery">
                        @if (allImages.Count > 0)
                        {
                            @for (int i = 0; i < allImages.Count; i++)
                            {
                                <img src="@allImages[i]"
                                     alt="@p.Name @(i+1)"
                                     class="gallery-img @(i == 0 ? "active" : "")"
                                     id="img-@i"
                                     onerror="this.style.display='none'" />
                            }
                            if (allImages.Count > 1)
                            {
                                <button class="gallery-nav prev" onclick="galleryNav(-1)">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>
                                <button class="gallery-nav next" onclick="galleryNav(1)">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            }
                        }
                        else
                        {
                            <div class="gallery-placeholder">
                                <i class="fa-regular fa-image" style="font-size:48px;opacity:.2"></i>
                                <span>Görsel Yok</span>
                            </div>
                        }
                    </div>
                    @if (allImages.Count > 1)
                    {
                        <div class="gallery-dots">
                            @for (int i = 0; i < allImages.Count; i++)
                            {
                                <button class="gallery-dot @(i == 0 ? "active" : "")" id="dot-@i"
                                        onclick="galleryGoTo(@i)"></button>
                            }
                        </div>
                    }
                </div>

                <!-- Kimlik Bilgileri -->
                <div style="display:flex;flex-direction:column;gap:14px">
                    <!-- Durum Rozetleri -->
                    <div style="display:flex;gap:8px;flex-wrap:wrap">
                        @if (p.IsActive)
                        {
                            <span class="badge-nova badge-green"><i class="fa-solid fa-circle-check"></i> Aktif</span>
                        }
                        else
                        {
                            <span class="badge-nova badge-gray"><i class="fa-solid fa-circle-xmark"></i> Pasif</span>
                        }
                        <span class="badge-nova badge-cyan">@p.Category?.Name</span>
                    </div>

                    <!-- SKU -->
                    <div>
                        <div style="font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px">SKU</div>
                        <span class="sku-badge">@p.SKU</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ② Depo Dağılımı -->
        <div class="glass-card p-4">
            <div style="font-size:15px;font-weight:600;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                <i class="fa-solid fa-warehouse" style="color:var(--cyan);margin-right:8px"></i>
                Depo Bazlı Stok Dağılımı
                <span style="float:right;font-size:13px;color:var(--text-muted)">Toplam: <strong style="color:var(--@(isCrit ? "red" : "green"))">@p.StockCount Adet</strong></span>
            </div>

            @if (p.ProductWarehouses.Any())
            {
                <div style="display:flex;flex-direction:column;gap:14px">
                    @foreach (var pw in p.ProductWarehouses.OrderByDescending(w => w.Quantity))
                    {
                        var pct = p.StockCount > 0 ? (int)((pw.Quantity / (double)p.StockCount) * 100) : 0;
                        var barColor = pw.Quantity == 0 ? "var(--red)" : pw.Quantity <= p.CriticalStockLevel ? "var(--yellow)" : "var(--accent)";
                        <div>
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                                <div>
                                    <span style="font-size:13px;font-weight:600">@pw.Warehouse?.Name</span>
                                    @if (!string.IsNullOrEmpty(pw.Location))
                                    {
                                        <span style="font-size:11px;color:var(--text-muted);margin-left:8px">
                                            <i class="fa-solid fa-location-dot"></i> @pw.Location
                                        </span>
                                    }
                                </div>
                                <span style="font-size:13px;font-weight:700;color:@barColor">@pw.Quantity Adet</span>
                            </div>
                            <div class="stock-bar-wrap">
                                <div class="stock-bar-fill" style="width:@pct%;background:@barColor"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Kritik Stok Eşiği -->
                <div class="inner-glass-box" style="margin-top:18px;padding:12px">
                    <div style="display:flex;justify-content:space-between;font-size:13px">
                        <span style="color:var(--text-muted)"><i class="fa-solid fa-triangle-exclamation" style="color:var(--yellow)"></i> Kritik Eşik</span>
                        <span style="font-weight:700;color:var(--yellow)">@p.CriticalStockLevel Adet</span>
                    </div>
                    <div class="stock-bar-wrap" style="margin-top:8px;height:6px">
                        @{
                            var critPct = p.StockCount > 0 ? Math.Min((int)((p.CriticalStockLevel / (double)p.StockCount) * 100), 100) : 100;
                        }
                        <div class="stock-bar-fill" style="width:@critPct%;background:var(--yellow)"></div>
                    </div>
                </div>
            }
            else
            {
                <div style="text-align:center;padding:32px;color:var(--text-muted)">
                    <i class="fa-solid fa-box-open" style="font-size:32px;opacity:.2;display:block;margin-bottom:10px"></i>
                    Bu ürün henüz hiçbir depoya atanmamış.
                </div>
            }
        </div>
        <!-- ③ Satış Grafiği -->
        <div class="glass-card p-4">
            <div style="font-size:15px;font-weight:600;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                <i class="fa-solid fa-chart-line" style="color:var(--green);margin-right:8px"></i>
                Son 6 Aylık Satış Trendi
            </div>
            @if (Model.MonthlySales.Count > 0)
            {
                <canvas id="salesChart" height="200"></canvas>
            }
            else
            {
                <div style="text-align:center;padding:32px;color:var(--text-muted)">
                    <i class="fa-solid fa-chart-line" style="font-size:32px;opacity:.2;display:block;margin-bottom:10px"></i>
                    Son 6 ayda bu ürüne ait satış verisi bulunmuyor.
                </div>
            }
        </div>

        <!-- ④ Teknik Özellikler -->
        @if (specs.Technical.Count > 0)
        {
            <div class="glass-card p-4">
                <div style="font-size:15px;font-weight:600;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                    <i class="fa-solid fa-microchip" style="color:var(--accent-light);margin-right:8px"></i>
                    Teknik Özellikler
                </div>
                <div class="specs-kv-grid">
                    @foreach (var kv in specs.Technical)
                    {
                        <div class="specs-kv-row">
                            <div>@kv.Key</div>
                            <div>@kv.Value</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ⑤ Lojistik & Paketleme -->
        @{
            var log = specs.Logistics;
            var hasLogistics = log.WeightGrams.HasValue || log.WidthCm.HasValue || log.HeightCm.HasValue || log.DepthCm.HasValue || log.Desi.HasValue;
        }
        @if (hasLogistics)
        {
            <div class="glass-card p-4">
                <div style="font-size:15px;font-weight:600;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                    <i class="fa-solid fa-truck-ramp-box" style="color:var(--yellow);margin-right:8px"></i>
                    Lojistik & Paketleme
                </div>
                <div class="specs-kv-grid">
                    @if (log.WeightGrams.HasValue)
                    {
                        <div class="specs-kv-row">
                            <div>Ağırlık (Net)</div>
                            <div>@log.WeightGrams g</div>
                        </div>
                    }
                    @if (log.WidthCm.HasValue && log.HeightCm.HasValue && log.DepthCm.HasValue)
                    {
                        <div class="specs-kv-row">
                            <div>Kutu Boyutu</div>
                            <div>@log.WidthCm cm × @log.HeightCm cm × @log.DepthCm cm</div>
                        </div>
                    }
                    @if (log.Desi.HasValue)
                    {
                        <div class="specs-kv-row">
                            <div>Desi (Hacim Ağırlığı)</div>
                            <div>@log.Desi.Value.ToString("N2") desi</div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- ⑥ Son Siparişler -->
        @if (Model.RecentOrders.Count > 0)
        {
            <div class="glass-card p-4">
                <div style="font-size:15px;font-weight:600;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                    <i class="fa-solid fa-clock-rotate-left" style="color:var(--text-muted);margin-right:8px"></i>
                    Son Siparişler
                </div>
                <div style="overflow-x:auto">
                    <table class="nova-table">
                        <thead>
                            <tr>
                                <th>Sipariş No</th>
                                <th>Bayi</th>
                                <th>Adet</th>
                                <th>Birim Fiyat</th>
                                <th>Tarih</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var o in Model.RecentOrders)
                            {
                                var statusClass = o.Status switch {
                                    "Approved"   => "badge-green",
                                    "Pending"    => "badge-yellow",
                                    "Shipped"    => "badge-cyan",
                                    "Delivered"  => "badge-green",
                                    "Cancelled"  => "badge-red",
                                    _            => "badge-gray"
                                };
                                var statusLabel = o.Status switch {
                                    "Approved"   => "Onaylandı",
                                    "Pending"    => "Beklemede",
                                    "Shipped"    => "Kargoda",
                                    "Delivered"  => "Teslim Edildi",
                                    "Cancelled"  => "İptal",
                                    _            => o.Status
                                };
                                <tr>
                                    <td><a href="/Order/Detail/@o.OrderId" style="color:var(--accent-light)">@o.OrderNumber</a></td>
                                    <td>@o.DealerName</td>
                                    <td style="font-weight:700">@o.Quantity</td>
                                    <td>@o.UnitPrice.ToString("N2") ₺</td>
                                    <td style="font-size:12px;color:var(--text-muted)">@o.OrderDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                    <td><span class="badge-nova @statusClass recent-status-badge">@statusLabel</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <!-- ══════════════════ SAĞ SÜTUN ══════════════════ -->
        <!-- B2B Fiyat Matrisi -->
        <div class="glass-card p-4">
            <div style="font-size:15px;font-weight:600;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                <i class="fa-solid fa-tags" style="color:var(--gold);margin-right:8px"></i>
                B2B Fiyat Matrisi
            </div>

            @if (p.CostPrice.HasValue)
            {
                <div class="inner-glass-box" style="margin-bottom:14px;padding:12px">
                    <div style="font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px">Maliyet Fiyatı</div>
                    <div style="font-size:22px;font-weight:800;margin-top:4px">@p.CostPrice.Value.ToString("N2") ₺</div>
                </div>
            }

            <!-- Taban -->
            <div class="inner-glass-box" style="margin-bottom:10px;padding:12px">
                <div style="font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px">Taban Fiyat (Liste)</div>
                <div style="font-size:22px;font-weight:800;margin-top:4px">@p.BasePrice.ToString("N2") ₺</div>
                <div style="font-size:11px;color:var(--text-muted);margin-top:4px">
                    KDV Dahil (%@vatRate): <strong>@((p.BasePrice * (1 + vatRate / 100m)).ToString("N2")) ₺</strong>
                </div>
            </div>

            @if (p.PriceUSD.HasValue)
            {
                <div class="inner-glass-box" style="margin-bottom:14px;padding:10px 12px">
                    <div style="font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px">USD Karşılığı</div>
                    <div style="font-size:16px;font-weight:700;color:var(--green);margin-top:2px">$ @p.PriceUSD.Value.ToString("N2")</div>
                </div>
            }

            <!-- Kademeli Fiyatlar -->
            <div style="display:flex;flex-direction:column;gap:10px">
                <!-- Bronze -->
                <div class="price-tier-card" style="border-color:rgba(205,127,50,.3)">
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        <div>
                            <span class="badge-nova badge-bronze" style="font-size:11px">🥉 Bronze</span>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:4px">%0 indirim</div>
                        </div>
                        <div style="text-align:right">
                            <div style="font-size:18px;font-weight:800;color:var(--bronze)">@bronzePrice.ToString("N2") ₺</div>
                            @if (p.CostPrice.HasValue)
                            {
                                <div style="font-size:11px;color:var(--text-muted)">Kâr Marjı: <strong style="color:var(--green)">%@bronzeMargin</strong></div>
                            }
                        </div>
                    </div>
                </div>
                <!-- Silver -->
                <div class="price-tier-card" style="border-color:rgba(192,192,192,.3)">
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        <div>
                            <span class="badge-nova badge-silver" style="font-size:11px">🥈 Silver</span>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:4px">%5 indirim</div>
                        </div>
                        <div style="text-align:right">
                            <div style="font-size:18px;font-weight:800;color:var(--silver)">@silverPrice.ToString("N2") ₺</div>
                            @if (p.CostPrice.HasValue)
                            {
                                <div style="font-size:11px;color:var(--text-muted)">Kâr Marjı: <strong style="color:var(--green)">%@silverMargin</strong></div>
                            }
                        </div>
                    </div>
                </div>
                <!-- Gold -->
                <div class="price-tier-card" style="border-color:rgba(255,215,0,.3)">
                    <div style="display:flex;justify-content:space-between;align-items:center">
                        <div>
                            <span class="badge-nova badge-gold" style="font-size:11px">🥇 Gold</span>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:4px">%10 indirim</div>
                        </div>
                        <div style="text-align:right">
                            <div style="font-size:18px;font-weight:800;color:var(--gold)">@goldPrice.ToString("N2") ₺</div>
                            @if (p.CostPrice.HasValue)
                            {
                                <div style="font-size:11px;color:var(--text-muted)">Kâr Marjı: <strong style="color:var(--green)">%@goldMargin</strong></div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// ── Galeri Carousel ──────────────────────────────────────────────────────────
const totalImages = @allImages.Count;
let currentImg    = 0;
let autoTimer     = null;

function galleryGoTo(idx) {
    if (totalImages === 0) return;
    document.getElementById('img-' + currentImg)?.classList.remove('active');
    document.getElementById('dot-' + currentImg)?.classList.remove('active');
    currentImg = (idx + totalImages) % totalImages;
    document.getElementById('img-' + currentImg)?.classList.add('active');
    document.getElementById('dot-' + currentImg)?.classList.add('active');
}

function galleryNav(dir) {
    clearInterval(autoTimer);
    galleryGoTo(currentImg + dir);
    startAutoplay();
}

function startAutoplay() {
    if (totalImages <= 1) return;
    autoTimer = setInterval(() => galleryGoTo(currentImg + 1), 1500);
}

startAutoplay();

// ── Satış Grafiği ────────────────────────────────────────────────────────────
@if (Model.MonthlySales.Count > 0)
{
    <text>
    const salesLabels = [@Html.Raw(string.Join(",", Model.MonthlySales.Select(m => $"\"{m.Month}\"")))];
    const salesQty    = [@Html.Raw(string.Join(",", Model.MonthlySales.Select(m => m.Quantity)))];
    const salesRev    = [@Html.Raw(string.Join(",", Model.MonthlySales.Select(m => m.Revenue)))];

    const ctx = document.getElementById('salesChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: salesLabels,
            datasets: [
                {
                    label: 'Satılan Adet',
                    data: salesQty,
                    borderColor: 'rgba(99,179,237,1)',
                    backgroundColor: 'rgba(99,179,237,.1)',
                    tension: .4, fill: true, pointRadius: 5,
                    pointBackgroundColor: 'rgba(99,179,237,1)',
                    yAxisID: 'y'
                },
                {
                    label: 'Gelir (₺)',
                    data: salesRev,
                    borderColor: 'rgba(72,199,142,1)',
                    backgroundColor: 'rgba(72,199,142,.05)',
                    tension: .4, fill: false, pointRadius: 5,
                    pointBackgroundColor: 'rgba(72,199,142,1)',
                    yAxisID: 'y1'
                }
            ]
        },
        options: {
            responsive: true,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { labels: { color: '#aaa', font: { size: 12 } } },
                tooltip: {
                    callbacks: {
                        label: ctx => ctx.datasetIndex === 1
                            ? ctx.dataset.label + ': ' + ctx.raw.toLocaleString('tr-TR', {minimumFractionDigits:2}) + ' ₺'
                            : ctx.dataset.label + ': ' + ctx.raw + ' Adet'
                    }
                }
            },
            scales: {
                x: { ticks: { color: '#777' }, grid: { color: 'rgba(255,255,255,.04)' } },
                y: {
                    type: 'linear', position: 'left',
                    ticks: { color: '#777' }, grid: { color: 'rgba(255,255,255,.04)' }
                },
                y1: {
                    type: 'linear', position: 'right',
                    ticks: { color: '#777', callback: v => v.toLocaleString('tr-TR', {minimumFractionDigits:0}) + ' ₺' },
                    grid: { drawOnChartArea: false }
                }
            }
        }
    });
    </text>
}
</script>
}
