@model NovaStock.Web.ViewModels.ProductFormViewModel
@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    bool isEdit = Model.Id > 0;
}

<div class="page-header">
    <div>
        <h1><i class="fa-solid fa-@(isEdit ? "pen" : "plus")" style="color:var(--accent-light);margin-right:10px"></i>
            @(isEdit ? "Ürün Düzenle" : "Yeni Ürün Ekle")
        </h1>
        <div class="breadcrumb-nova"><a href="/Product" style="color:var(--accent-light);text-decoration:none">Ürünler</a> / @(isEdit ? Model.Name : "Yeni")</div>
    </div>
    <a href="/Product" class="btn-nova-outline"><i class="fa-solid fa-arrow-left"></i> Geri</a>
</div>

<form method="post" action="/Product/@(isEdit ? $"Edit/{Model.Id}" : "Create")">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="glass-card p-4">
                <div style="font-size:15px;font-weight:600;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                    <i class="fa-solid fa-circle-info" style="color:var(--accent-light);margin-right:8px"></i>Temel Bilgiler
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label-nova" asp-for="Name">Ürün Adı *</label>
                        <input asp-for="Name" class="form-nova" placeholder="Örn: Apple iPhone 15 Pro" />
                        <span asp-validation-for="Name" style="color:var(--red);font-size:12px"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-nova" asp-for="SKU">SKU Kodu *</label>
                        <input asp-for="SKU" class="form-nova" placeholder="Örn: APL-IPH15P" />
                        <span asp-validation-for="SKU" style="color:var(--red);font-size:12px"></span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label-nova" asp-for="Barcode">Barkod</label>
                        <input asp-for="Barcode" class="form-nova barcode-input" placeholder="Okutun veya yazın" />
                    </div>
                    <div class="col-12">
                        <label class="form-label-nova" asp-for="Description">Açıklama</label>
                        <textarea asp-for="Description" class="form-nova" rows="3" placeholder="Ürün hakkında kısa açıklama..."></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-nova" asp-for="CategoryId">Kategori *</label>
                        <select asp-for="CategoryId" class="form-nova">
                            <option value="">-- Kategori Seçin --</option>
                            @foreach (var c in Model.Categories)
                            {
                                if (Model.CategoryId == c.Id)
                                {
                                    <option value="@c.Id" selected>@c.Name</option>
                                }
                                else
                                {
                                    <option value="@c.Id">@c.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="CategoryId" style="color:var(--red);font-size:12px"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-nova" asp-for="SupplierId">Tedarikçi (Opsiyonel)</label>
                        <select asp-for="SupplierId" class="form-nova">
                            <option value="">-- Tedarikçi Seçin --</option>
                            @foreach (var s in Model.Suppliers)
                            {
                                if (Model.SupplierId == s.Id)
                                {
                                    <option value="@s.Id" selected>@s.Name</option>
                                }
                                else
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label-nova" asp-for="ImageUrl">Ana Görsel URL (opsiyonel)</label>
                        <input asp-for="ImageUrl" class="form-nova" placeholder="https://example.com/image.jpg" />
                    </div>

                    <!-- Çoklu Görsel URL'leri -->
                    <div class="col-12">
                        <div style="font-size:13px;font-weight:600;margin-bottom:8px;color:var(--text-muted)">
                            <i class="fa-solid fa-images" style="margin-right:6px"></i>Galeri Görselleri (URL)
                            <span style="font-size:11px;font-weight:400;margin-left:8px">(Her satıra bir URL)</span>
                        </div>
                        <textarea id="imageUrlsInput" class="form-nova" rows="3"
                                  placeholder="https://example.com/img1.jpg&#10;https://example.com/img2.jpg"
                                  style="font-family:monospace;font-size:12px"></textarea>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                    <!-- API Otomatik Doldur Butonu -->
                    <div class="col-12">
                        <div style="padding:14px;border-radius:12px;background:rgba(99,179,237,.06);border:1px solid rgba(99,179,237,.2)">
                            <div style="font-size:13px;font-weight:600;color:var(--accent-light);margin-bottom:10px">
                                <i class="fa-solid fa-bolt"></i> API'den Otomatik Doldur
                            </div>
                            <div style="display:flex;gap:8px">
                                <input type="text" id="apiSearchQuery" class="form-nova" style="flex:1"
                                       placeholder="Örn: Samsung Galaxy S24" />
                                <button type="button" class="btn-nova" id="fetchSpecsBtn" onclick="fetchSpecs()">
                                    <i class="fa-solid fa-magnifying-glass"></i> Getir
                                </button>
                            </div>
                            <div id="fetchResult" style="margin-top:8px;font-size:12px;color:var(--text-muted)"></div>
                        </div>
                    </div>
                    }

                    <!-- Gizli SpecsJson alanı -->
                    <input type="hidden" asp-for="SpecsJson" id="specsJsonInput" />
                </div>
            </div>
        </div>

        <!-- Teknik Özellikler -->
        <div class="col-12">
            <div class="glass-card p-4">
                <div style="font-size:15px;font-weight:600;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                    <i class="fa-solid fa-microchip" style="color:var(--accent-light);margin-right:8px"></i>
                    Teknik Özellikler
                    <span style="font-size:11px;color:var(--text-muted);font-weight:400;margin-left:8px">(Opsiyonel)</span>
                </div>
                <div id="techSpecsContainer" style="display:flex;flex-direction:column;gap:8px"></div>
                <button type="button" onclick="addTechSpec()" class="btn-nova-outline" style="margin-top:10px;font-size:12px">
                    <i class="fa-solid fa-plus"></i> Satır Ekle
                </button>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="glass-card p-4 mb-3">
                <div style="font-size:15px;font-weight:600;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                    <i class="fa-solid fa-turkish-lira-sign" style="color:var(--green);margin-right:8px"></i>Fiyat & Stok
                </div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label-nova" asp-for="BasePrice">Taban Fiyat (₺) *</label>
                        <input asp-for="BasePrice" type="number" step="0.01" class="form-nova" placeholder="0.00" id="basePriceInput" />
                        <span asp-validation-for="BasePrice" style="color:var(--red);font-size:12px"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label-nova" asp-for="CostPrice">Maliyet Fiyatı (₺)</label>
                        <input asp-for="CostPrice" type="number" step="0.01" class="form-nova" placeholder="0.00" />
                    </div>
                    <div class="col-6">
                        <label class="form-label-nova" asp-for="VatRate">KDV Oranı (%)</label>
                        <select asp-for="VatRate" class="form-nova">
                            <option value="0">%0 (KDV'siz)</option>
                            <option value="1">%1</option>
                            <option value="10">%10</option>
                            <option value="20" selected>%20</option>
                        </select>
                    </div>

                    <!-- Bayi fiyat önizlemesi -->
                    <div class="col-12">
                        <div style="background:rgba(0,0,0,0.2);border-radius:10px;padding:12px">
                            <div style="font-size:11px;color:var(--text-muted);margin-bottom:8px;font-weight:600">BAYİ FİYAT ÖNIZLEMESI</div>
                            <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                                <span style="font-size:12px;color:var(--bronze)"><i class="fa-solid fa-circle"></i> Bronze</span>
                                <span id="bronzePrice" style="font-size:12px;font-weight:600;color:var(--bronze)">-</span>
                            </div>
                            <div style="display:flex;justify-content:space-between;margin-bottom:6px">
                                <span style="font-size:12px;color:var(--silver)"><i class="fa-solid fa-circle"></i> Silver (-5%)</span>
                                <span id="silverPrice" style="font-size:12px;font-weight:600;color:var(--silver)">-</span>
                            </div>
                            <div style="display:flex;justify-content:space-between">
                                <span style="font-size:12px;color:var(--gold)"><i class="fa-solid fa-circle"></i> Gold (-10%)</span>
                                <span id="goldPrice" style="font-size:12px;font-weight:600;color:var(--gold)">-</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <label class="form-label-nova" asp-for="StockCount">Stok Miktarı *</label>
                        <input asp-for="StockCount" type="number" min="0" class="form-nova" />
                        <span asp-validation-for="StockCount" style="color:var(--red);font-size:12px"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label-nova" asp-for="CriticalStockLevel">Kritik Eşik</label>
                        <input asp-for="CriticalStockLevel" type="number" min="1" class="form-nova" />
                    </div>
                </div>
            </div>

            <div class="glass-card p-4">
                <div style="font-size:15px;font-weight:600;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid var(--border-glass)">
                    <i class="fa-solid fa-gear" style="color:var(--yellow);margin-right:8px"></i>Durum
                </div>
                <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
                    <input asp-for="IsActive" type="checkbox" style="width:18px;height:18px;accent-color:var(--accent)">
                    <span style="font-size:14px">Ürün aktif</span>
                </label>
            </div>
        </div>

        <div class="col-12">
            <div style="display:flex;gap:12px;justify-content:flex-end">
                <a href="/Product" class="btn-nova-outline">
                    <i class="fa-solid fa-xmark"></i> İptal
                </a>
                <button type="submit" class="btn-nova">
                    <i class="fa-solid fa-floppy-disk"></i>
                    @(isEdit ? "Değişiklikleri Kaydet" : "Ürünü Ekle")
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
    // ── Fiyat Önizleme ───────────────────────────────────────────────────────
    const basePriceInput = document.getElementById('basePriceInput');
    function updatePrices() {
        const base = parseFloat(basePriceInput.value) || 0;
        const fmt = v => v.toLocaleString('tr-TR', {minimumFractionDigits:2, maximumFractionDigits:2}) + ' ₺';
        document.getElementById('bronzePrice').textContent = fmt(base);
        document.getElementById('silverPrice').textContent = fmt(base * 0.95);
        document.getElementById('goldPrice').textContent   = fmt(base * 0.90);
    }
    basePriceInput.addEventListener('input', updatePrices);
    updatePrices();

    // ── Teknik Özellikler Editörü ─────────────────────────────────────────────
    function addTechSpec(key = '', value = '') {
        const container = document.getElementById('techSpecsContainer');
        const row = document.createElement('div');
        row.style.cssText = 'display:flex;gap:8px;align-items:center';
        row.innerHTML = `
            <input type="text" class="form-nova spec-key" placeholder="Özellik (Örn: RAM)" value="${key}" style="flex:1" />
            <input type="text" class="form-nova spec-val" placeholder="Değer (Örn: 8 GB)" value="${value}" style="flex:2" />
            <button type="button" onclick="this.parentElement.remove()"
                    style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:var(--red);
                           width:34px;height:34px;border-radius:8px;cursor:pointer;flex-shrink:0">
                <i class="fa-solid fa-xmark"></i>
            </button>`;
        container.appendChild(row);
    }

    // ── Mevcut SpecsJson'u forma yükle ───────────────────────────────────────
    (function loadExistingSpecs() {
        const raw = document.getElementById('specsJsonInput')?.value;
        if (!raw) return;
        try {
            const data = JSON.parse(raw);
            if (data.ImageUrls?.length) {
                document.getElementById('imageUrlsInput').value = data.ImageUrls.join('\n');
            }
            if (data.Technical) {
                Object.entries(data.Technical).forEach(([k, v]) => addTechSpec(k, v));
            }
        } catch {}
    })();

    // ── Form Submit'te SpecsJson oluştur ─────────────────────────────────────
    document.querySelector('form').addEventListener('submit', function() {
        const imageLines = (document.getElementById('imageUrlsInput')?.value || '')
            .split('\n').map(l => l.trim()).filter(l => l);

        const tech = {};
        document.querySelectorAll('#techSpecsContainer > div').forEach(row => {
            const k = row.querySelector('.spec-key')?.value.trim();
            const v = row.querySelector('.spec-val')?.value.trim();
            if (k && v) tech[k] = v;
        });

        const specsData = {
            ImageUrls: imageLines,
            Technical: tech,
            Logistics: {},
            Compliance: {}
        };

        document.getElementById('specsJsonInput').value = JSON.stringify(specsData);
    });

    // ── API'den Otomatik Doldur ───────────────────────────────────────────────
    async function fetchSpecs() {
        const query = document.getElementById('apiSearchQuery')?.value.trim();
        if (!query) return;
        const btn = document.getElementById('fetchSpecsBtn');
        const result = document.getElementById('fetchResult');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Aranıyor...';
        result.textContent = '';
        try {
            const res  = await fetch(`/Product/FetchSpecs?query=${encodeURIComponent(query)}`);
            const data = await res.json();
            if (!data.found) {
                result.innerHTML = `<span style="color:var(--yellow)"><i class="fa-solid fa-triangle-exclamation"></i> ${data.message || 'Sonuç bulunamadı.'}</span>`;
                return;
            }
            // Teknik özellikleri doldur
            document.getElementById('techSpecsContainer').innerHTML = '';
            if (data.specs) {
                Object.entries(data.specs).forEach(([k, v]) => addTechSpec(k, v));
            }
            // Ana görseli doldur
            if (data.thumbnail) {
                const imgInput = document.querySelector('[name="ImageUrl"]');
                if (imgInput && !imgInput.value) imgInput.value = data.thumbnail;
                const urlsArea = document.getElementById('imageUrlsInput');
                if (urlsArea && !urlsArea.value.includes(data.thumbnail)) {
                    urlsArea.value = (urlsArea.value ? urlsArea.value + '\n' : '') + data.thumbnail;
                }
            }

            result.innerHTML = `<span style="color:var(--green)"><i class="fa-solid fa-check"></i> "${data.phoneName}" için ${Object.keys(data.specs||{}).length} özellik yüklendi!</span>`;
        } catch (err) {
            result.innerHTML = `<span style="color:var(--red)"><i class="fa-solid fa-xmark"></i> Bağlantı hatası.</span>`;
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-magnifying-glass"></i> Getir';
        }
    }
</script>
}
