@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap – NovaStock ERP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
        <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
        body{font-family:'Inter',sans-serif;background:#f4f7fb;color:#1e293b;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden}
        .bg-grid{position:fixed;inset:0;background-image:linear-gradient(rgba(99,102,241,0.06) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,0.06) 1px,transparent 1px);background-size:48px 48px;pointer-events:none}
        .bg-glow{position:fixed;top:-200px;left:50%;transform:translateX(-50%);width:700px;height:500px;background:radial-gradient(ellipse,rgba(99,102,241,0.15),transparent 70%);pointer-events:none}
        .login-card{background:rgba(255,255,255,0.9);border:1px solid rgba(0,0,0,0.08);border-radius:20px;padding:40px;width:100%;max-width:440px;position:relative;backdrop-filter:blur(20px);box-shadow:0 20px 60px rgba(0,0,0,0.05)}
        .login-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#6366f1,#0ea5e9);border-radius:20px 20px 0 0}
        .brand{text-align:center;margin-bottom:32px}
        .brand-icon{width:56px;height:56px;background:linear-gradient(135deg,#6366f1,#4f46e5);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:24px;color:#fff;margin:0 auto 12px;box-shadow:0 0 30px rgba(99,102,241,0.25)}
        .brand-name{font-size:22px;font-weight:800;background:linear-gradient(90deg,#4f46e5,#0ea5e9);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
        .brand-sub{font-size:13px;color:#64748b;margin-top:4px}
        .form-group{margin-bottom:18px}
        .form-label{font-size:13px;font-weight:500;color:#475569;margin-bottom:6px;display:block}
        .form-input{width:100%;background:#ffffff;border:1px solid rgba(0,0,0,0.15);border-radius:12px;color:#1e293b;padding:12px 16px;font-size:14px;font-family:'Inter',sans-serif;transition:all 0.2s;outline:none}
        .form-input:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,0.2);background:#ffffff}
        .form-input-icon{position:relative}
        .form-input-icon i{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#64748b;font-size:14px}
        .form-input-icon input{padding-left:42px}
        .btn-login{width:100%;background:linear-gradient(135deg,#6366f1,#4f46e5);color:#fff;border:none;border-radius:12px;padding:13px;font-size:15px;font-weight:700;cursor:pointer;transition:all 0.25s;font-family:'Inter',sans-serif;margin-top:4px}
        .btn-login:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(99,102,241,0.35)}
        .divider{text-align:center;font-size:12px;color:#64748b;margin:20px 0;position:relative}
        .divider::before,.divider::after{content:'';position:absolute;top:50%;width:42%;height:1px;background:rgba(0,0,0,0.08)}
        .divider::before{left:0}.divider::after{right:0}
        .demo-box{background:rgba(99,102,241,0.05);border:1px solid rgba(99,102,241,0.15);border-radius:12px;padding:14px;margin-top:20px}
        .demo-box h4{font-size:12px;font-weight:600;color:#4f46e5;margin-bottom:10px;text-transform:uppercase;letter-spacing:0.8px}
        .demo-row{display:flex;justify-content:space-between;font-size:12px;margin-bottom:6px;cursor:pointer;padding:4px 0}
        .demo-row:hover .demo-cred{color:#6366f1}
        .demo-label{color:#475569}
        .demo-cred{color:#64748b;font-family:monospace;font-size:11px;transition:color 0.2s}
        .validation-error{color:#ef4444;font-size:12px;margin-top:4px;display:block}
        .link{color:#6366f1;text-decoration:none;font-size:13px}
        .link:hover{color:#4f46e5}
        .remember-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;font-size:13px}
        .remember-label{display:flex;align-items:center;gap:7px;color:#475569;cursor:pointer}
        input[type=checkbox]{accent-color:#6366f1}
    </style>
</head>
<body>
    <div class="bg-grid"></div>
    <div class="bg-glow"></div>

    <div class="login-card">
        <div class="brand">
            <div class="brand-icon"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div class="brand-name">NovaStock ERP</div>
            <div class="brand-sub">Kurumsal Stok & Bayi Yönetim Sistemi</div>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:12px 14px;margin-bottom:18px;font-size:13px;color:#ef4444">
                <i class="fa-solid fa-triangle-exclamation" style="margin-right:8px"></i>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    @error.ErrorMessage
                }
            </div>
        }

        <form method="post" asp-action="Login" asp-controller="Account">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="form-group">
                <label class="form-label">E-Posta Adresi</label>
                <div class="form-input-icon">
                    <i class="fa-solid fa-envelope"></i>
                    <input name="Email" type="email" class="form-input" placeholder="admin@novastock.com" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Şifre</label>
                <div class="form-input-icon">
                    <i class="fa-solid fa-lock"></i>
                    <input name="Password" type="password" class="form-input" placeholder="••••••••" required />
                </div>
            </div>

            <div class="remember-row">
                <label class="remember-label">
                    <input name="RememberMe" type="checkbox" value="true">
                    Beni hatırla
                </label>
                <a href="/Account/Register" class="link">Hesap oluştur →</a>
            </div>

            <button type="submit" class="btn-login">
                <i class="fa-solid fa-right-to-bracket" style="margin-right:8px"></i>Giriş Yap
            </button>
        </form>

        <!-- Demo Giriş Bilgileri -->
        <div class="demo-box">
            <h4><i class="fa-solid fa-circle-info" style="margin-right:6px"></i>Demo Hesapları</h4>
            <div class="demo-row" onclick="fillLogin('admin@novastock.com','Admin1234!')">
                <span class="demo-label"><i class="fa-solid fa-shield-halved" style="color:#a78bfa;margin-right:6px"></i>Admin</span>
                <span class="demo-cred">admin@novastock.com / Admin1234!</span>
            </div>
            <div class="demo-row" onclick="fillLogin('bayi@novastock.com','Bayi1234!')">
                <span class="demo-label"><i class="fa-solid fa-user" style="color:#06b6d4;margin-right:6px"></i>Bayi</span>
                <span class="demo-cred">bayi@novastock.com / Bayi1234!</span>
            </div>
        </div>
    </div>

    <script>
        function fillLogin(email, pass) {
            document.querySelector('input[name="Email"]').value    = email;
            document.querySelector('input[name="Password"]').value = pass;
        }
    </script>
</body>
</html>

