@model List<NovaStock.Web.ViewModels.SubUserViewModel>
@{
    ViewData["Title"] = "Ekip Yönetimi";
}

@section Styles {
<style>
.team-card {
    display: flex; align-items: center; gap: 16px;
    padding: 18px 20px; border-bottom: 1px solid var(--border-glass);
    transition: background .15s;
}
.team-card:hover { background: rgba(255,255,255,.02); }
.team-avatar {
    width: 44px; height: 44px; border-radius: 50%; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700; color: #fff;
    background: linear-gradient(135deg, var(--accent), var(--cyan));
}
.add-form-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }
@@media (max-width:700px) { .add-form-grid { grid-template-columns: 1fr; } }
.fi { display: flex; flex-direction: column; gap: 5px; }
.fi label { font-size: 12px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: .6px; }
.fi input, .fi select {
    padding: 10px 14px; border: 1.5px solid var(--border-glass);
    border-radius: 10px; background: var(--bg-body); color: var(--text-primary);
    font-size: 13px; transition: border-color .2s;
}
.fi input:focus, .fi select:focus { outline: none; border-color: var(--accent); }
</style>
}

<div class="page-header">
    <div>
        <h1><i class="fa-solid fa-users-gear" style="color:var(--accent-light);margin-right:10px"></i>Ekip Yönetimi</h1>
        <div class="breadcrumb-nova">Alt Kullanıcı (Sub-User) Yönetimi · @ViewBag.DealerName</div>
    </div>
    <a href="/" class="btn-nova-outline"><i class="fa-solid fa-arrow-left"></i> Dashboard</a>
</div>

<!-- ── Yetki Bilgilendirme Kartları ─────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="glass-card p-4" style="border-top:3px solid var(--cyan)">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
                <div style="width:40px;height:40px;border-radius:10px;background:rgba(6,182,212,.15);display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--cyan)">
                    <i class="fa-solid fa-cart-shopping"></i>
                </div>
                <div>
                    <div style="font-weight:700">Satın Alma Personeli</div>
                    <code style="font-size:11px;color:var(--text-muted)">DealerPurchase</code>
                </div>
            </div>
            <ul style="font-size:12px;color:var(--text-muted);margin:0;padding-left:18px;line-height:2">
                <li>✅ Katalogdan ürün inceleyebilir</li>
                <li>✅ Sepete ürün ekleyip sipariş oluşturabilir</li>
                <li>❌ Cari hesap ekstresi görüntüleyemez</li>
                <li>❌ Siparişi onaylayıp borcalandıramaz</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6">
        <div class="glass-card p-4" style="border-top:3px solid var(--green)">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">
                <div style="width:40px;height:40px;border-radius:10px;background:rgba(16,185,129,.15);display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--green)">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                </div>
                <div>
                    <div style="font-weight:700">Muhasebe Personeli</div>
                    <code style="font-size:11px;color:var(--text-muted)">DealerFinance</code>
                </div>
            </div>
            <ul style="font-size:12px;color:var(--text-muted);margin:0;padding-left:18px;line-height:2">
                <li>✅ Cari hesap ekstresini görüntüleyebilir</li>
                <li>✅ PDF/Excel ekstre indirebilir</li>
                <li>❌ Katalog ve ürün fiyatlarını göremez</li>
                <li>❌ Sipariş oluşturamaz</li>
            </ul>
        </div>
    </div>
</div>

<!-- ── Yeni Ekip Üyesi Ekle ──────────────────────────────────────────────────── -->
<div class="glass-card mb-4 p-4">
    <div style="font-size:15px;font-weight:600;margin-bottom:20px">
        <i class="fa-solid fa-user-plus" style="color:var(--green);margin-right:8px"></i>Yeni Ekip Üyesi Ekle
    </div>
    <form asp-action="AddSubUser" asp-controller="Dealer" method="post">
        @Html.AntiForgeryToken()
        <div class="add-form-grid">
            <div class="fi">
                <label>Ad Soyad *</label>
                <input type="text" name="FullName" placeholder="Ahmet Yılmaz" required />
            </div>
            <div class="fi">
                <label>E-posta *</label>
                <input type="email" name="Email" placeholder="satin-alma@sirket.com" required />
            </div>
            <div class="fi">
                <label>Şifre *</label>
                <input type="password" name="Password" placeholder="En az 6 karakter" required minlength="6" />
            </div>
        </div>
        <div style="margin-top:14px;display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <div class="fi" style="min-width:240px">
                <label>Rol *</label>
                <select name="Role">
                    <option value="DealerPurchase">🛒 Satın Alma Personeli</option>
                    <option value="DealerFinance">📊 Muhasebe Personeli</option>
                </select>
            </div>
            <button type="submit" class="btn-nova" style="margin-top:auto">
                <i class="fa-solid fa-user-plus"></i> Ekle
            </button>
        </div>
    </form>
</div>

<!-- ── Mevcut Ekip Üyeleri ──────────────────────────────────────────────────── -->
<div class="glass-card">
    <div style="padding:18px 20px;border-bottom:1px solid var(--border-glass);font-size:15px;font-weight:600">
        <i class="fa-solid fa-users" style="color:var(--accent-light);margin-right:8px"></i>
        Mevcut Ekip Üyeleri
        <span class="badge-nova badge-purple" style="font-size:12px;margin-left:8px">@Model.Count üye</span>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:50px;color:var(--text-muted)">
            <i class="fa-solid fa-users" style="font-size:36px;opacity:.2;display:block;margin-bottom:14px"></i>
            Henüz ekip üyesi eklemediniz.
        </div>
    }
    else
    {
        foreach (var u in Model)
        {
            var roleColor = u.Role == "DealerFinance" ? "var(--green)" : "var(--cyan)";
            var roleIcon  = u.Role == "DealerFinance" ? "fa-file-invoice-dollar" : "fa-cart-shopping";

            <div class="team-card">
                <div class="team-avatar">@u.FullName[0].ToString().ToUpper()</div>
                <div style="flex:1;min-width:0">
                    <div style="font-weight:700;font-size:14px">@u.FullName</div>
                    <div style="font-size:12px;color:var(--text-muted)">@u.Email</div>
                </div>
                <div style="text-align:center;min-width:160px">
                    <span class="badge-nova" style="background:@(u.Role == "DealerFinance" ? "rgba(16,185,129,.15)" : "rgba(6,182,212,.15)");color:@roleColor;border:1px solid @roleColor">
                        <i class="fa-solid @roleIcon" style="margin-right:4px;font-size:10px"></i>@u.RoleLabel
                    </span>
                </div>
                <div style="min-width:80px;text-align:center">
                    @if (u.IsActive)
                    {
                        <span class="badge-nova badge-green"><i class="fa-solid fa-circle-check"></i> Aktif</span>
                    }
                    else
                    {
                        <span class="badge-nova badge-gray">Pasif</span>
                    }
                </div>
                <div style="font-size:11px;color:var(--text-muted);min-width:90px;text-align:right">
                    @u.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                </div>
                @if (u.IsActive)
                {
                    <form asp-action="RemoveSubUser" asp-controller="Dealer" method="post" style="margin:0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="subUserId" value="@u.Id" />
                        <button type="submit" class="btn-nova-outline" style="padding:5px 10px;font-size:11px;color:var(--red);border-color:var(--red)"
                            onclick="return confirm('@u.FullName hesabını devre dışı bırakmak istiyor musunuz?')">
                            <i class="fa-solid fa-ban"></i>
                        </button>
                    </form>
                }
            </div>
        }
    }
</div>
